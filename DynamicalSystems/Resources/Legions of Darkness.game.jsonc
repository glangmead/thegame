  "actions": {
    "actions": [
      {"name": "initialize"},
      {"name": "drawCard"},
      {"name": "advanceArmies"},
      {"name": "skipEvent"},
      // ── Simple events (no choice) ──
      {"name": "catapultShrapnel"}, {"name": "rocksOfAges"},
      {"name": "actsOfValor"}, {"name": "distractedDefenders"},
      {"name": "brokenWalls"}, {"name": "lamentationOfWomen"},
      {"name": "reignOfArrows"}, {"name": "trappedByFlames"},
