      {"name": "gateTrack", "length": 5, "tags": ["army", "gate"],
       "displayNames": ["G0", "G1", "G2", "G3", "G4"]},
      {"name": "skyTrack", "length": 7, "tags": ["army", "sky"],
       "displayNames": ["S0", "S1", "S2", "S3", "S4", "S5", "S6"]},
      {"name": "terrorTrack", "length": 4, "tags": ["army", "terror"],
       "displayNames": ["T0", "T1", "T2", "T3"]},
      {"name": "timeTrack", "length": 16, "tags": ["time"],
       "displayNames": ["D0", "d1", "d2", "T3", "n4", "n5",
                         "D6", "d7", "d8", "T9", "n10", "n11",
                         "D12", "d13", "d14", "T15"]},
      {"name": "moraleTrack", "length": 3, "tags": ["status"],
       "displayNames": ["Low", "Normal", "High"]},
      {"name": "menAtArmsTrack", "length": 6, "tags": ["defender"],
       "displayNames": ["MaA:3", "MaA:2", "MaA:2", "MaA:2", "MaA:1", "MaA:0"]},
      {"name": "archersTrack", "length": 5, "tags": ["defender"],
       "displayNames": ["Arc:2", "Arc:2", "Arc:1", "Arc:1", "Arc:0"]},
      {"name": "priestsTrack", "length": 4, "tags": ["defender"],
       "displayNames": ["Pri:2", "Pri:2", "Pri:1", "Pri:0"]},
      {"name": "arcaneTrack", "length": 7, "tags": ["energy"],
       "displayNames": ["a0", "a1", "a2", "a3", "a4", "a5", "a6"]},
      {"name": "divineTrack", "length": 7, "tags": ["energy"],
       "displayNames": ["d0", "d1", "d2", "d3", "d4", "d5", "d6"]}
    ],
    "connections": []
  },

  // ═══════════════════════════════════════════════════════════════
  // ACTIONS
  // ═══════════════════════════════════════════════════════════════
  "actions": {
    "actions": [
      {"name": "initialize"},
      {"name": "drawCard"},
      {"name": "advanceArmies"},
      {"name": "skipEvent"},
      // ── Simple events (no choice) ──
      {"name": "catapultShrapnel"}, {"name": "rocksOfAges"},
      {"name": "actsOfValor"}, {"name": "distractedDefenders"},
      {"name": "brokenWalls"}, {"name": "lamentationOfWomen"},
      {"name": "reignOfArrows"}, {"name": "trappedByFlames"},
      {"name": "bannersInDistance"}, {"name": "campfires"},
      {"name": "councilOfHeroes"}, {"name": "paleMoonlight"},
      {"name": "midnightMagic"}, {"name": "waningMoon"},
      {"name": "mysticForcesReborn"}, {"name": "deathAndDespairEvent"},
      // ── Choice events ──
      {"name": "bumpAdvanceSky"}, {"name": "bumpAdvanceOther",
       "params": [{"name": "slot1", "type": "ArmySlot"}, {"name": "slot2", "type": "ArmySlot"}]},
      {"name": "desertersLoseDefenders",
       "params": [{"name": "def1", "type": "DefenderType"}, {"name": "def2", "type": "DefenderType"}]},
      {"name": "desertersLoseMorale"},
      {"name": "bloodyHandprints", "params": [{"name": "hero", "type": "HeroType"}]},
      {"name": "bloodyHandprintsNoHeroes"},
      {"name": "assassinsCreedo", "params": [{"name": "hero", "type": "HeroType"}]},
      {"name": "assassinsCreedoNoHeroes"},
      {"name": "harbingersChoose", "params": [{"name": "slot", "type": "ArmySlot"}]},
      {"name": "harbingersAuto"},
      // ── Death and Despair sub-resolution ──
      {"name": "ddSacrificeHero", "params": [{"name": "hero", "type": "HeroType"}]},
      {"name": "ddSacrificeDefender", "params": [{"name": "defType", "type": "DefenderType"}]},
      {"name": "ddCommitAdvance"},
      // ── Combat ──
      {"name": "melee", "params": [{"name": "slot", "type": "ArmySlot"}]},
      {"name": "ranged", "params": [{"name": "slot", "type": "ArmySlot"}]},
      // ── Build ──
      {"name": "buildUpgrade", "params": [{"name": "upgrade", "type": "UpgradeType"},
                                           {"name": "track", "type": "Track"}]},
      {"name": "barricade", "params": [{"name": "track", "type": "Track"}]},
      // ── Magic actions ──
      {"name": "chant"}, {"name": "memorize"}, {"name": "pray"},
      // ── Spell casts ──
      {"name": "castFireball", "params": [{"name": "slot", "type": "ArmySlot"}]},
      {"name": "castFireballHeroic", "params": [{"name": "slot", "type": "ArmySlot"}]},
      {"name": "castSlowNormal", "params": [{"name": "slot", "type": "ArmySlot"}]},
      {"name": "castSlowHeroic", "params": [{"name": "slot", "type": "ArmySlot"}]},
      {"name": "castCureWoundsNormal", "params": [{"name": "hero", "type": "HeroType"}]},
      {"name": "castCureWoundsHeroic", "params": [{"name": "hero1", "type": "HeroType"},
                                                   {"name": "hero2", "type": "HeroType"}]},
      {"name": "castMassHealNormal", "params": [{"name": "defType", "type": "DefenderType"}]},
      {"name": "castMassHealHeroic", "params": [{"name": "def1", "type": "DefenderType"},
                                                 {"name": "def2", "type": "DefenderType"}]},
      {"name": "castDivineWrathNormal", "params": [{"name": "slot", "type": "ArmySlot"}]},
      {"name": "castDivineWrathHeroic", "params": [{"name": "slot1", "type": "ArmySlot"},
                                                    {"name": "slot2", "type": "ArmySlot"}]},
      {"name": "castInspireNormal"}, {"name": "castInspireHeroic"},
      {"name": "castRaiseDeadDefenders", "params": [{"name": "def1", "type": "DefenderType"},
                                                     {"name": "def2", "type": "DefenderType"}]},
      {"name": "castRaiseDeadHero", "params": [{"name": "hero", "type": "HeroType"}]},
      {"name": "castRaiseDeadHeroicBoth", "params": [{"name": "def1", "type": "DefenderType"},
                                                      {"name": "def2", "type": "DefenderType"},
                                                      {"name": "hero", "type": "HeroType"}]},
      {"name": "castChainLightningNormal"}, {"name": "castChainLightningHeroic"},
      {"name": "castFortuneNormal"}, {"name": "castFortuneHeroic"},
      // ── Chain Lightning targeting ──
      {"name": "lightningBolt", "params": [{"name": "slot", "type": "ArmySlot"}]},
      // ── Fortune sub-resolution ──
      {"name": "fortuneDiscard", "params": [{"name": "index", "type": "Int"}]},
      {"name": "fortuneSkipDiscard"},
      {"name": "fortuneReorder", "params": [{"name": "order", "type": "Int"}]},
      // ── Heroic actions ──
      {"name": "moveHero", "params": [{"name": "hero", "type": "HeroType"},
                                       {"name": "location", "type": "HeroLocation"}]},
      {"name": "heroicAttack", "params": [{"name": "hero", "type": "HeroType"},
                                           {"name": "slot", "type": "ArmySlot"}]},
      {"name": "rally"},
      // ── Quest actions ──
      {"name": "questAction", "params": [{"name": "points", "type": "Int", "min": 1, "max": 6}]},
      {"name": "questHeroic", "params": [{"name": "points", "type": "Int", "min": 1, "max": 6}]},
      // ── Quest rewards ──
      {"name": "scrollsOfTheDead", "params": [{"name": "spell", "type": "SpellType"}]},
      {"name": "putForthTheCall", "params": [{"name": "defType", "type": "DefenderType"}]},
      {"name": "lastDitchEfforts", "params": [{"name": "hero", "type": "HeroType"}]},
      {"name": "pillarsOfTheEarth", "params": [{"name": "slot", "type": "ArmySlot"}]},
      {"name": "prophecyRevealed", "params": [{"name": "discardIndex", "type": "Int"}]},
      // ── Free actions ──
      {"name": "rogueMove", "params": [{"name": "location", "type": "HeroLocation"}]},
      {"name": "acidMeleeAttack", "params": [{"name": "slot", "type": "ArmySlot"}]},
      // ── Bloody battle gate tie ──
      {"name": "chooseBloodyBattle", "params": [{"name": "slot", "type": "ArmySlot"}]},
      {"name": "chooseBloodyBattleGate1"}, {"name": "chooseBloodyBattleGate2"},
      // ── Phase transitions ──
      {"name": "endPlayerTurn"},
      {"name": "performHousekeeping"},
      // ── Paladin reroll ──
      {"name": "paladinReroll"}, {"name": "declineReroll"},
      // ── Defender choice ──
      {"name": "loseDefenderArchers"}, {"name": "loseDefenderMenAtArms"}, {"name": "loseDefenderPriests"}, {"name": "loseDefenderNoneAvailable"},
      // ── Victory / defeat ──
      {"name": "claimVictory"}, {"name": "declareLoss"}
    ],
    "groups": [
      {"name": "Combat", "actions": ["melee", "ranged"]},
      {"name": "Fortification", "actions": ["buildUpgrade", "barricade"]},
      {"name": "Magic", "actions": ["chant", "memorize", "pray",
                                     "castFireball", "castFireballHeroic",
                                     "castSlowNormal", "castSlowHeroic",
                                     "castCureWoundsNormal", "castCureWoundsHeroic",
                                     "castMassHealNormal", "castMassHealHeroic",
                                     "castDivineWrathNormal", "castDivineWrathHeroic",
                                     "castInspireNormal", "castInspireHeroic",
                                     "castRaiseDeadDefenders", "castRaiseDeadHero", "castRaiseDeadHeroicBoth",
                                     "castChainLightningNormal", "castChainLightningHeroic",
                                     "castFortuneNormal", "castFortuneHeroic"]},
      {"name": "Heroic", "actions": ["moveHero", "heroicAttack", "rally"]},
      {"name": "Quest", "actions": ["questAction", "questHeroic",
                                     "scrollsOfTheDead", "putForthTheCall", "lastDitchEfforts",
                                     "pillarsOfTheEarth", "prophecyRevealed"]},
      {"name": "Event", "actions": ["catapultShrapnel", "rocksOfAges", "actsOfValor",
                                     "distractedDefenders", "brokenWalls", "lamentationOfWomen",
                                     "reignOfArrows", "trappedByFlames", "bannersInDistance",
                                     "campfires", "councilOfHeroes", "paleMoonlight",
                                     "midnightMagic", "waningMoon", "mysticForcesReborn",
                                     "deathAndDespairEvent",
                                     "bumpAdvanceSky", "bumpAdvanceOther",
                                     "desertersLoseDefenders", "desertersLoseMorale",
                                     "bloodyHandprints", "bloodyHandprintsNoHeroes",
                                     "assassinsCreedo", "assassinsCreedoNoHeroes",
                                     "harbingersChoose", "harbingersAuto",
                                     "skipEvent"]}
    ]
  },

  // ═══════════════════════════════════════════════════════════════
  // RULES
  // ═══════════════════════════════════════════════════════════════
  "rules": {
    "terminal": "gameAcknowledged",
    "rolloutTerminal": "ended",
    "redeterminize": ["dayDeck", "nightDeck"],

    "pages": [
      // ── Setup ──────────────────────────────────────────────────
      {
        "page": "Setup",
        "rules": [
          {"when": {"==": ["phase", ".setup"]},
           "offer": ["initialize"]}
        ],
        "reduce": {
          "initialize": {"seq": [
            // Greenskin Horde: army positions
            {"setEntry": ["armyPosition", "east", 6]},
            {"setEntry": ["armyPosition", "west", 6]},
            {"setEntry": ["armyPosition", "gate1", 4]},
            {"setEntry": ["armyPosition", "gate2", 4]},
            {"setEntry": ["armyPosition", "sky", 6]},
            // Place army pieces on their tracks
            {"place": ["east", {"site": ["eastTrack", 6]}]},
            {"place": ["west", {"site": ["westTrack", 6]}]},
            {"place": ["gate1", {"site": ["gateTrack", 4]}]},
            {"place": ["gate2", {"site": ["gateTrack", 4]}]},
            {"place": ["sky", {"site": ["skyTrack", 6]}]},
            // Terror: not placed until first twilight (timePosition 3)
            // Army strengths
            {"setEntry": ["armyStrengthDict", "east", 2]},
            {"setEntry": ["armyStrengthDict", "west", 2]},
            {"setEntry": ["armyStrengthDict", "gate1", 3]},
            {"setEntry": ["armyStrengthDict", "gate2", 3]},
            {"setEntry": ["armyStrengthDict", "sky", 4]},
            {"setEntry": ["armyStrengthDict", "terror", 4]},
            // Heroes: warrior, wizard, cleric in reserves
            {"setEntry": ["heroLocationDict", "warrior", ".reserves"]},
            {"setEntry": ["heroLocationDict", "wizard", ".reserves"]},
            {"setEntry": ["heroLocationDict", "cleric", ".reserves"]},
            // Defenders at starting positions (position 0 = full strength)
            {"setEntry": ["defenderPosition", "menAtArms", 0]},
            {"setEntry": ["defenderPosition", "archers", 0]},
            {"setEntry": ["defenderPosition", "priests", 0]},
            // Place defender pieces on their tracks
            {"place": ["menAtArms", {"site": ["menAtArmsTrack", 0]}]},
            {"place": ["archers", {"site": ["archersTrack", 0]}]},
            {"place": ["priests", {"site": ["priestsTrack", 0]}]},
            // Spells all face-down
            {"setEntry": ["spellStatusDict", "fireball", ".faceDown"]},
            {"setEntry": ["spellStatusDict", "slow", ".faceDown"]},
            {"setEntry": ["spellStatusDict", "chainLightning", ".faceDown"]},
            {"setEntry": ["spellStatusDict", "fortune", ".faceDown"]},
            {"setEntry": ["spellStatusDict", "cureWounds", ".faceDown"]},
            {"setEntry": ["spellStatusDict", "massHeal", ".faceDown"]},
            {"setEntry": ["spellStatusDict", "divineWrath", ".faceDown"]},
            {"setEntry": ["spellStatusDict", "inspire", ".faceDown"]},
            {"setEntry": ["spellStatusDict", "raiseDead", ".faceDown"]},
            // Morale normal
            {"set": ["morale", ".normal"]},
            // Winds of Magic: roll d6 for arcane base, divine = 6 - arcane
            // Wizard +2 arcane (if alive), Cleric +2 divine (if alive), capped at 6
            {"let": ["roll", {"rollDie": [6]},
              "wizBonus", {"if": [{"not": [{"contains": ["heroDead", ".wizard"]}]}, 2, 0]},
              "clrBonus", {"if": [{"not": [{"contains": ["heroDead", ".cleric"]}]}, 2, 0]},
              {"seq": [
                {"set": ["arcaneEnergy", {"min": [6, {"+": ["$roll", "$wizBonus"]}]}]},
                {"set": ["divineEnergy", {"min": [6, {"+": [{"-": [6, "$roll"]}, "$clrBonus"]}]}]},
                {"log": [{"format": ["Winds of Magic: rolled {}, arcane={}, divine={}",
                  "$roll", "arcaneEnergy", "divineEnergy"]}]}
              ]}
            ]},
            // Time at position 0 (First Dawn)
            {"set": ["timePosition", 0]},
            // Pending roll = none
            {"set": ["pendingRoll", ".none"]},
            // Shuffle decks
            {"shuffle": ["dayDeck"]},
            {"shuffle": ["nightDeck"]},
            // Transition to card phase
            {"setPhase": [".card"]}
          ]}
        }
      },

      // ── Card Phase ─────────────────────────────────────────────
      {
        "page": "Card Phase",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".card"]},
                             {"not": ["bloodyBattleGateTied"]}]},
           "offer": ["drawCard"]}
        ],
        "reduce": {
          "drawCard": {"seq": [
            // Draw from day deck during dawn/day, night deck during twilight/night
            // Time spaces 0,1,2,6,7,8,12,13,14 = day; 3,4,5,9,10,11,15 = night
            {"if": [{"drawsFromDayDeck": []},
              {"draw": ["dayDeck", "currentCard"]},
              {"draw": ["nightDeck", "currentCard"]}
            ]},
            {"log": [{"format": ["Drew card #{}: {}",
              {"get": ["currentCard", "number"]},
              {"get": ["currentCard", "title"]}]}]},
            {"chain": ["advanceArmies"]}
          ]}
        }
      },

      // ── Army Phase ─────────────────────────────────────────────
      {
        "page": "Army Phase",
        "rules": [],
        "reduce": {
          "advanceArmies": {"seq": [
            // Advance armies per card's advance icons
            {"advanceArmiesFromCard": []},
            // Place bloody battle marker from card (if not "none" and not gate)
            {"if": [{"and": [{"!=": [{"get": ["currentCard", "bloodyBattle"]}, "none"]},
                              {"!=": [{"get": ["currentCard", "bloodyBattle"]}, "gate"]}]},
              {"seq": [
                {"set": ["bloodyBattleArmy",
                  {"if": [{"==": [{"get": ["currentCard", "bloodyBattle"]}, "east"]}, ".east",
                    {"if": [{"==": [{"get": ["currentCard", "bloodyBattle"]}, "west"]}, ".west",
                      {"if": [{"==": [{"get": ["currentCard", "bloodyBattle"]}, "sky"]}, ".sky",
                        ".terror"]}]}]}]},
                {"log": [{"format": ["Bloody battle on {}", {"get": ["currentCard", "bloodyBattle"]}]}]}
              ]}
            ]},
            // Rule 3.2: Gate bloody battle — closer army gets marker. Tie = player chooses.
            {"if": [{"==": [{"get": ["currentCard", "bloodyBattle"]}, "gate"]},
              {"let": ["g1Pos", {"lookup": ["armyPosition", "gate1"]},
                "g2Pos", {"lookup": ["armyPosition", "gate2"]},
                {"if": [{"and": [{"==": ["$g1Pos", null]}, {"==": ["$g2Pos", null]}]},
                  {"log": ["Bloody battle gate: no gate armies"]},
                  {"if": [{"==": ["$g2Pos", null]},
                    {"seq": [{"set": ["bloodyBattleArmy", ".gate1"]},
                             {"log": ["Bloody battle on gate1 (only gate army)"]}]},
                    {"if": [{"==": ["$g1Pos", null]},
                      {"seq": [{"set": ["bloodyBattleArmy", ".gate2"]},
                               {"log": ["Bloody battle on gate2 (only gate army)"]}]},
                      // Both present: compare positions (lower = closer to castle)
                      {"if": [{"<": ["$g1Pos", "$g2Pos"]},
                        {"seq": [{"set": ["bloodyBattleArmy", ".gate1"]},
                                 {"log": ["Bloody battle on gate1 (closer)"]}]},
                        {"if": [{">": ["$g1Pos", "$g2Pos"]},
                          {"seq": [{"set": ["bloodyBattleArmy", ".gate2"]},
                                   {"log": ["Bloody battle on gate2 (closer)"]}]},
                          // Tied — set pending flag for player choice
                          {"seq": [{"set": ["bloodyBattleGateTied", true]},
                                   {"log": ["Bloody battle gate: tied, player chooses"]}]}
                        ]}
                      ]}
                    ]}
                  ]}
                ]}
              ]}
            ]},
            // Transition: if no gate tie pending, proceed to event or action
            {"if": [{"not": ["bloodyBattleGateTied"]},
              {"if": [{"!=": [{"get": ["currentCard", "eventNumber"]}, 0]},
                {"setPhase": [".event"]},
                {"setPhase": [".action"]}
              ]}
            ]}
          ]}
        }
      },

      // ── Bloody Battle Gate Tie Choice ────────────────────────
      // Rule 3.2: when both gate armies are equidistant, player chooses
      {
        "page": "Bloody Battle Gate Choice",
        "rules": [
          {"when": "bloodyBattleGateTied",
           "offer": ["chooseBloodyBattleGate1", "chooseBloodyBattleGate2"]}
        ],
        "reduce": {
          "chooseBloodyBattleGate1": {"seq": [
            {"set": ["bloodyBattleArmy", ".gate1"]},
            {"set": ["bloodyBattleGateTied", false]},
            {"log": ["Bloody battle: player chose gate1"]},
            {"if": [{"!=": [{"get": ["currentCard", "eventNumber"]}, 0]},
              {"setPhase": [".event"]},
              {"setPhase": [".action"]}
            ]}
          ]},
          "chooseBloodyBattleGate2": {"seq": [
            {"set": ["bloodyBattleArmy", ".gate2"]},
            {"set": ["bloodyBattleGateTied", false]},
            {"log": ["Bloody battle: player chose gate2"]},
            {"if": [{"!=": [{"get": ["currentCard", "eventNumber"]}, 0]},
              {"setPhase": [".event"]},
              {"setPhase": [".action"]}
            ]}
          ]}
        }
      },

      // ── No Event ───────────────────────────────────────────────
      {
        "page": "No Event",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".event"]},
                             {"==": [{"get": ["currentCard", "eventNumber"]}, 0]}]},
           "offer": ["skipEvent"]}
        ],
        "reduce": {
          "skipEvent": {"setPhase": [".action"]}
        }
      },

      // ── Event: Card 1 ───────────────────────────────────────────
      {
        "page": "Event 1",
        "rules": [
          {"when": {"isEventCard": [1]},
           "offer": ["catapultShrapnel"]}
        ],
        "reduce": {
          "catapultShrapnel": {"let": ["roll", {"rollDie": [6]},
            {"seq": [
              {"if": [{"==": ["$roll", 1]},
                {"loseDefender": ["archers"]},
                {"if": [{"<=": ["$roll", 3]},
                  {"loseDefender": ["menAtArms"]},
                  {"log": ["No effect"]}
                ]}
              ]},
              {"log": [{"format": ["Event 1: rolled {}", "$roll"]}]},
              {"setPhase": [".action"]}
            ]}
          ]}
        }
      },

      // ── Event: Card 4 ────────────────────────────────────────────
      {
        "page": "Event 4",
        "rules": [
          {"when": {"isEventCard": [4]},
           "offer": ["rocksOfAges"]}
        ],
        "reduce": {
          "rocksOfAges": {"let": ["roll", {"rollDie": [6]},
            {"seq": [
              {"if": [{"==": ["$roll", 1]},
                {"loseDefender": ["priests"]},
                {"if": [{"<=": ["$roll", 3]},
                  {"loseDefender": ["menAtArms"]},
                  {"log": ["No effect"]}
                ]}
              ]},
              {"log": [{"format": ["Event 4: rolled {}", "$roll"]}]},
              {"setPhase": [".action"]}
            ]}
          ]}
        }
      },

      // ── Event: Card 8 ────────────────────────────────────────────
      {
        "page": "Event 8",
        "rules": [
          {"when": {"isEventCard": [8]},
           "offer": ["actsOfValor"]}
        ],
        "reduce": {
          "actsOfValor": {"let": ["hadUnwounded", {"anyHeroUnwounded": []},
            {"seq": [
              // Wound all unwounded heroes; if any were unwounded, +1 attack DRM
              {"woundAllUnwoundedHeroes": []},
              {"if": ["$hadUnwounded",
                {"seq": [
                  {"increment": ["eventAttackDRMBonus", 1]},
                  {"log": ["Event 8: +1 DRM from wounded heroes"]}
                ]},
                {"log": ["Event 8: no unwounded heroes to wound"]}
              ]},
              {"setPhase": [".action"]}
            ]}
          ]}
        }
      },

      // ── Event: Card 9 ─────────────────────────────────────────────
      {
        "page": "Event 9",
        "rules": [
          {"when": {"isEventCard": [9]},
           "offer": ["distractedDefenders"]}
        ],
        "reduce": {
          "distractedDefenders": {"seq": [
            // If East army out of melee range (space > 3), advance it
            {"if": [{"and": [{"!=": [{"lookup": ["armyPosition", "east"]}, null]},
                              {">": [{"lookup": ["armyPosition", "east"]}, 3]}]},
              {"advanceSingleArmy": ["east"]},
              {"log": ["East army in melee range or not on board"]}
            ]},
            {"setPhase": [".action"]}
          ]}
        }
      },

      // ── Event: Card 14 ────────────────────────────────────────────
      {
        "page": "Event 14",
        "rules": [
          {"when": {"isEventCard": [14]},
           "offer": ["brokenWalls"]}
        ],
        "reduce": {
          "brokenWalls": {"seq": [
            {"advanceClosestEastWest": []},
            {"setPhase": [".action"]}
          ]}
        }
      },

      // ── Event: Card 16 ────────────────────────────────────────────
      {
        "page": "Event 16",
        "rules": [
          {"when": {"isEventCard": [16]},
           "offer": ["lamentationOfWomen"]}
        ],
        "reduce": {
          "lamentationOfWomen": {"let": ["roll", {"rollDie": [6]},
            {"seq": [
              {"if": [{"<=": ["$roll", 3]},
                {"lowerMorale": []},
                {"set": ["noMeleeThisTurn", true]}
              ]},
              {"log": [{"format": ["Event 16: rolled {}", "$roll"]}]},
              {"setPhase": [".action"]}
            ]}
          ]}
        }
      },

      // ── Event: Card 17 ─────────────────────────────────────────────
      {
        "page": "Event 17",
        "rules": [
          {"when": {"isEventCard": [17]},
           "offer": ["reignOfArrows"]}
        ],
        "reduce": {
          "reignOfArrows": {"let": ["roll", {"rollDie": [6]},
            {"seq": [
              {"if": [{"==": ["$roll", 1]},
                {"loseDefender": ["priests"]},
                {"if": [{"<=": ["$roll", 3]},
                  {"loseDefender": ["archers"]},
                  {"log": ["No effect"]}
                ]}
              ]},
              {"log": [{"format": ["Event 17: rolled {}", "$roll"]}]},
              {"setPhase": [".action"]}
            ]}
          ]}
        }
      },

      // ── Event: Card 18 ───────────────────────────────────────────
      {
        "page": "Event 18",
        "rules": [
          {"when": {"isEventCard": [18]},
           "offer": ["trappedByFlames"]}
        ],
        "reduce": {
          "trappedByFlames": {"let": ["roll", {"rollDie": [6]},
            {"seq": [
              {"if": [{"<=": ["$roll", 2]},
                {"loseDefender": ["menAtArms"]},
                {"if": [{"<=": ["$roll", 4]},
                  {"seq": [{"loseDefender": ["archers"]}, {"loseDefender": ["priests"]}]},
                  {"log": ["No effect"]}
                ]}
              ]},
              {"log": [{"format": ["Event 18: rolled {}", "$roll"]}]},
              {"setPhase": [".action"]}
            ]}
          ]}
        }
      },

      // ── Event: Card 20 ─────────────────────────────────────────────
      {
        "page": "Event 20",
        "rules": [
          {"when": {"isEventCard": [20]},
           "offer": ["bannersInDistance"]}
        ],
        "reduce": {
          "bannersInDistance": {"seq": [
            {"if": [{"and": [{"!=": [{"lookup": ["armyPosition", "west"]}, null]},
                              {">": [{"lookup": ["armyPosition", "west"]}, 3]}]},
              {"advanceSingleArmy": ["west"]},
              {"log": ["West army in melee range or not on board"]}
            ]},
            {"setPhase": [".action"]}
          ]}
        }
      },

      // ── Event: Card 23 ───────────────────────────────────────────
      {
        "page": "Event 23",
        "rules": [
          {"when": {"isEventCard": [23]},
           "offer": ["campfires"]}
        ],
        "reduce": {
          "campfires": {"seq": [
            // Advance gate armies that are out of melee range (space > 3)
            {"if": [{"and": [{"!=": [{"lookup": ["armyPosition", "gate1"]}, null]},
                              {">": [{"lookup": ["armyPosition", "gate1"]}, 3]}]},
              {"advanceSingleArmy": ["gate1"]},
              {"log": ["Gate1 in range or absent"]}
            ]},
            {"if": [{"and": [{"!=": [{"lookup": ["armyPosition", "gate2"]}, null]},
                              {">": [{"lookup": ["armyPosition", "gate2"]}, 3]}]},
              {"advanceSingleArmy": ["gate2"]},
              {"log": ["Gate2 in range or absent"]}
            ]},
            {"setPhase": [".action"]}
          ]}
        }
      },

      // ── Event: Card 26 ───────────────────────────────────────────
      {
        "page": "Event 26",
        "rules": [
          {"when": {"isEventCard": [26]},
           "offer": ["councilOfHeroes"]}
        ],
        "reduce": {
          "councilOfHeroes": {"seq": [
            // Return all living heroes to reserves
            {"returnAllHeroesToReserves": []},
            {"set": ["woundedHeroesCannotAct", true]},
            {"log": ["Event 26: heroes returned, wounded cannot act"]},
            {"setPhase": [".action"]}
          ]}
        }
      },

      // ── Event: Cards 27+32 ──────────────────────────────────────
      {
        "page": "Event 27/32",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".event"]},
                             {"or": [{"==": [{"get": ["currentCard", "eventNumber"]}, 27]},
                                     {"==": [{"get": ["currentCard", "eventNumber"]}, 32]}]}]},
           "offer": ["midnightMagic"]}
        ],
        "reduce": {
          "midnightMagic": {"let": ["roll", {"rollDie": [6]},
            {"seq": [
              {"if": [{"<=": ["$roll", 3]},
                {"set": ["arcaneEnergy", {"min": [6, {"+": ["arcaneEnergy", 1]}]}]},
                {"set": ["arcaneEnergy", {"min": [6, {"+": ["arcaneEnergy", 2]}]}]}
              ]},
              {"log": [{"format": ["Event 27/32: rolled {}", "$roll"]}]},
              {"setPhase": [".action"]}
            ]}
          ]}
        }
      },

      // ── Event: Card 31 ──────────────────────────────────────────
      {
        "page": "Event 31",
        "rules": [
          {"when": {"isEventCard": [31]},
           "offer": ["paleMoonlight"]}
        ],
        "reduce": {
          "paleMoonlight": {"seq": [
            {"set": ["divineEnergy", {"max": [0, {"-": ["divineEnergy", 1]}]}]},
            {"set": ["arcaneEnergy", {"min": [6, {"+": ["arcaneEnergy", 1]}]}]},
            {"loseDefender": ["priests"]},
            {"log": ["Event 31: -1 divine, +1 arcane, lose 1 priest"]},
            {"setPhase": [".action"]}
          ]}
        }
      },

      // ── Event: Card 34 ─────────────────────────────────────────────
      {
        "page": "Event 34",
        "rules": [
          {"when": {"isEventCard": [34]},
           "offer": ["waningMoon"]}
        ],
        "reduce": {
          "waningMoon": {"let": ["roll", {"rollDie": [6]},
            {"seq": [
              {"if": [{"<=": ["$roll", 3]},
                {"set": ["arcaneEnergy", {"max": [0, {"-": ["arcaneEnergy", 1]}]}]},
                {"set": ["arcaneEnergy", {"min": [6, {"+": ["arcaneEnergy", 1]}]}]}
              ]},
              {"log": [{"format": ["Event 34: rolled {}", "$roll"]}]},
              {"setPhase": [".action"]}
            ]}
          ]}
        }
      },

      // ── Event: Card 35 ────────────────────────────────────────────
      {
        "page": "Event 35",
        "rules": [
          {"when": {"isEventCard": [35]},
           "offer": ["mysticForcesReborn"]}
        ],
        "reduce": {
          "mysticForcesReborn": {"let": ["roll", {"rollDie": [6]},
            {"seq": [
              // Return all cast spells to face-down
              {"returnCastSpellsToFaceDown": []},
              {"if": [{"<=": ["$roll", 3]},
                {"set": ["arcaneEnergy", {"max": [0, {"-": ["arcaneEnergy", 1]}]}]},
                // Roll 4-6: draw random arcane spell (mark as known)
                {"memorizeRandomArcane": []}
              ]},
              {"log": [{"format": ["Event 35: rolled {}", "$roll"]}]},
              {"setPhase": [".action"]}
            ]}
          ]}
        }
      },

      // ── Event: Card 29 (trigger) ────────────────────────────────
      {
        "page": "Event 29",
        "rules": [
          {"when": {"isEventCard": [29]},
           "offer": ["deathAndDespairEvent"]}
        ],
        "reduce": {
          "deathAndDespairEvent": {"let": ["roll", {"rollDie": [6]},
            {"seq": [
              {"set": ["deathDespairDieRoll", "$roll"]},
              {"set": ["deathDespairSacrifices", 0]},
              {"set": ["inDeathAndDespair", true]},
              {"log": [{"format": ["Event 29: rolled {}. Choose sacrifices.", "$roll"]}]},
              {"setPhase": [".action"]}
            ]}
          ]}
        }
      },

      // ── Event 29 sub-resolution ────────────────────────────────
      {
        "page": "Event 29 Resolution",
        "rules": [
          {"when": "inDeathAndDespair",
           "offer": ["ddCommitAdvance"]}
        ],
        "reduce": {
          "ddSacrificeHero": {"seq": [
            {"woundHero": ["$hero"]},
            {"increment": ["deathDespairSacrifices", 1]},
            {"log": [{"format": ["D&D: wounded {} to reduce advance", "$hero"]}]}
          ]},
          "ddSacrificeDefender": {"seq": [
            {"loseDefender": ["$defType"]},
            {"increment": ["deathDespairSacrifices", 1]},
            {"log": [{"format": ["D&D: lost {} to reduce advance", "$defType"]}]}
          ]},
          "ddCommitAdvance": {"seq": [
            {"let": ["advances", {"max": [0, {"-": ["deathDespairDieRoll", "deathDespairSacrifices"]}]},
              {"advanceFarthestArmy": ["$advances"]}
            ]},
            {"set": ["inDeathAndDespair", false]},
            {"set": ["deathDespairDieRoll", 0]},
            {"set": ["deathDespairSacrifices", 0]},
            {"log": ["Event 29 resolved"]}
          ]}
        }
      },

      // ── Event: Card 36 ───────────────────────────────────────────
      // Rule: advance Sky 1 space OR advance 2 other armies 1 space each
      {
        "page": "Event 36",
        "rules": [
          {"when": {"isEventCard": [36]},
           "offer": ["bumpAdvanceSky", "bumpAdvanceOther"]}
        ],
        "reduce": {
          "bumpAdvanceSky": {"seq": [
            {"advanceSingleArmy": ["sky"]},
            {"log": ["Event 36: advanced Sky"]},
            {"setPhase": [".action"]}
          ]},
          "bumpAdvanceOther": {"seq": [
            {"advanceSingleArmy": ["$slot1"]},
            {"advanceSingleArmy": ["$slot2"]},
            {"log": [{"format": ["Event 36: advanced {} and {}", "$slot1", "$slot2"]}]},
            {"setPhase": [".action"]}
          ]}
        }
      },

      // ── Event: Card 33 ───────────────────────────────────────────
      // Rule: lose 2 defenders OR lower morale. Morale option only if not already low.
      {
        "page": "Event 33",
        "rules": [
          {"when": {"isEventCard": [33]},
           "offer": ["desertersLoseDefenders"]},
          {"when": {"and": [{"isEventCard": [33]},
                             {"!=": ["morale", ".low"]}]},
           "offer": ["desertersLoseMorale"]}
        ],
        "reduce": {
          "desertersLoseDefenders": {"seq": [
            {"loseDefender": ["$def1"]},
            {"loseDefender": ["$def2"]},
            {"log": [{"format": ["Event 33: lost {} and {}", "$def1", "$def2"]}]},
            {"setPhase": [".action"]}
          ]},
          "desertersLoseMorale": {"seq": [
            {"lowerMorale": []},
            {"log": ["Event 33: morale lowered"]},
            {"setPhase": [".action"]}
          ]}
        }
      },

      // ── Event: Card 24 ───────────────────────────────────────────
      // Player chooses a living hero. Roll: 1-3 kill, 4-6 wound.
      // Rule 8.2.1: wounded heroes must be chosen first.
      {
        "page": "Event 24",
        "rules": [
          {"when": {"isEventCard": [24]},
           "offer": ["bloodyHandprints"],
           "paramFilter": {"and": [{"heroAlive": ["$hero"]},
                                    {"or": [{"contains": ["heroWounded", "$hero"]},
                                            {"not": [{"anyLivingWoundedHero": []}]}]}]}},
          // No living heroes fallback
          {"when": {"and": [{"isEventCard": [24]},
                             {"not": [{"heroAlive": ["warrior"]}]},
                             {"not": [{"heroAlive": ["wizard"]}]},
                             {"not": [{"heroAlive": ["ranger"]}]},
                             {"not": [{"heroAlive": ["rogue"]}]},
                             {"not": [{"heroAlive": ["paladin"]}]},
                             {"not": [{"heroAlive": ["cleric"]}]}]},
           "offer": ["bloodyHandprintsNoHeroes"]}
        ],
        "reduce": {
          "bloodyHandprints": {"let": ["roll", {"rollDie": [6]},
            {"seq": [
              {"if": [{"<=": ["$roll", 3]}, {"killHero": ["$hero"]}, {"woundHero": ["$hero"]}]},
              {"log": [{"format": ["Event 24: rolled {}, hero {}", "$roll", "$hero"]}]},
              {"setPhase": [".action"]}
            ]}
          ]},
          "bloodyHandprintsNoHeroes": {"seq": [
            {"log": ["Event 24: no living heroes"]},
            {"setPhase": [".action"]}
          ]}
        }
      },

      // ── Event: Card 30 ───────────────────────────────────────────
      // Player chooses a living hero. Roll: 1-3 kill hero, 4-6 +1 attack DRM.
      {
        "page": "Event 30",
        "rules": [
          {"when": {"isEventCard": [30]},
           "offer": ["assassinsCreedo"],
           "paramFilter": {"heroAlive": ["$hero"]}},
          // No living heroes fallback
          {"when": {"and": [{"isEventCard": [30]},
                             {"not": [{"heroAlive": ["warrior"]}]},
                             {"not": [{"heroAlive": ["wizard"]}]},
                             {"not": [{"heroAlive": ["ranger"]}]},
                             {"not": [{"heroAlive": ["rogue"]}]},
                             {"not": [{"heroAlive": ["paladin"]}]},
                             {"not": [{"heroAlive": ["cleric"]}]}]},
           "offer": ["assassinsCreedoNoHeroes"]}
        ],
        "reduce": {
          "assassinsCreedo": {"let": ["roll", {"rollDie": [6]},
            {"seq": [
              {"if": [{"<=": ["$roll", 3]}, {"killHero": ["$hero"]}, {"increment": ["eventAttackDRMBonus", 1]}]},
              {"log": [{"format": ["Event 30: rolled {}, hero {}", "$roll", "$hero"]}]},
              {"setPhase": [".action"]}
            ]}
          ]},
          "assassinsCreedoNoHeroes": {"let": ["roll", {"rollDie": [6]},
            {"seq": [
              {"if": [{">": ["$roll", 3]},
                {"increment": ["eventAttackDRMBonus", 1]},
                {"log": ["No heroes to kill"]}
              ]},
              {"log": [{"format": ["Event 30: rolled {} (no heroes)", "$roll"]}]},
              {"setPhase": [".action"]}
            ]}
          ]}
        }
      },

      // ── Event: Card 11 ──────────────────────────────────────────
      // If multiple armies tied at farthest position, player chooses which to advance
      {
        "page": "Event 11",
        "rules": [
          // No tie: auto-advance the single farthest army
          {"when": {"and": [{"isEventCard": [11]},
                             {"<=": [{"farthestArmyTieCount": []}, 1]}]},
           "offer": ["harbingersAuto"]},
          // Tie: offer player choice among tied slots
          {"when": {"and": [{"isEventCard": [11]},
                             {">": [{"farthestArmyTieCount": []}, 1]}]},
           "offer": ["harbingersChoose"],
           "paramFilter": {"isSlotAtFarthestPos": ["$slot"]}}
        ],
        "reduce": {
          "harbingersChoose": {"seq": [
            {"advanceSingleArmy": ["$slot"]},
            {"log": [{"format": ["Event 11: player chose to advance {}", "$slot"]}]},
            {"setPhase": [".action"]}
          ]},
          "harbingersAuto": {"seq": [
            {"advanceFarthestArmy": [1]},
            {"log": ["Event 11: advanced farthest army"]},
            {"setPhase": [".action"]}
          ]}
        }
      },

      // ── Combat Page (Melee + Ranged) ───────────────────────────
      {
        "page": "Combat",
        "rules": [
          // Melee attacks — parameterized over ArmySlot
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []},
                             {"not": ["noMeleeThisTurn"]},
                             {"<": ["meleeAttacksThisTurn", {"menAtArmsValue": []}]}]},
           "offer": ["melee"],
           "paramFilter": {"inMeleeRange": ["$slot"]}},
          // Ranged attacks — parameterized over ArmySlot, not terror
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []},
                             {"<": ["rangedAttacksThisTurn", {"archersValue": []}]}]},
           "offer": ["ranged"],
           "paramFilter": {"and": [{"armyOnTrack": ["$slot"]},
                                    {"!=": ["$slot", "terror"]},
                                    {"gateTieBreak": ["$slot"]}]}}
        ],
        "reduce": {
          "melee": {"initiateMeleeAttack": ["$slot"]},
          "ranged": {"initiateRangedAttack": ["$slot"]}
        }
      },

      // ── Build Page (Upgrades + Barricades) ─────────────────────
      {
        "page": "Fortification",
        "rules": [
          // Upgrades: parameterized over UpgradeType × Track
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []}]},
           "offer": ["buildUpgrade"],
           "paramFilter": {"and": [
             {"!=": ["$track", "sky"]},
             {"!=": ["$track", "terror"]},
             {"==": [{"lookup": ["upgradeDict", "$track"]}, null]},
             {"not": [{"contains": ["breaches", "$track"]}]},
             {"if": [{"==": ["$track", "gate"]},
               {"and": [{"!=": [{"lookup": ["armyPosition", "gate1"]}, 1]},
                        {"!=": [{"lookup": ["armyPosition", "gate2"]}, 1]}]},
               {"let": ["pos", {"lookup": ["armyPosition", "$track"]},
                 {"or": [{"==": ["$pos", null]}, {"!=": ["$pos", 1]}]}
               ]}
             ]}
           ]}},
          // Barricades: parameterized over Track
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []}]},
           "offer": ["barricade"],
           "paramFilter": {"and": [
             {"!=": ["$track", "sky"]},
             {"!=": ["$track", "terror"]},
             {"contains": ["breaches", "$track"]}
           ]}}
        ],
        "reduce": {
          "buildUpgrade": {"resolveBuildUpgrade": ["$upgrade", "$track"]},
          "barricade": {"resolveBarricade": ["$track"]}
        }
      },

      // ── Magic Page (Chant, Memorize, Pray) ─────────────────────
      {
        "page": "Magic",
        "rules": [
          // Rule 6.5: Chant always available during action phase
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []}]},
           "offer": ["chant"]},
          // Rule 6.6: Memorize only if a face-down arcane spell exists
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []},
                             {"or": [{"==": [{"lookup": ["spellStatusDict", "fireball"]}, ".faceDown"]},
                                     {"==": [{"lookup": ["spellStatusDict", "slow"]}, ".faceDown"]},
                                     {"==": [{"lookup": ["spellStatusDict", "chainLightning"]}, ".faceDown"]},
                                     {"==": [{"lookup": ["spellStatusDict", "fortune"]}, ".faceDown"]}]}]},
           "offer": ["memorize"]},
          // Rule 6.7: Pray only if a face-down divine spell exists
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []},
                             {"or": [{"==": [{"lookup": ["spellStatusDict", "cureWounds"]}, ".faceDown"]},
                                     {"==": [{"lookup": ["spellStatusDict", "massHeal"]}, ".faceDown"]},
                                     {"==": [{"lookup": ["spellStatusDict", "divineWrath"]}, ".faceDown"]},
                                     {"==": [{"lookup": ["spellStatusDict", "inspire"]}, ".faceDown"]},
                                     {"==": [{"lookup": ["spellStatusDict", "raiseDead"]}, ".faceDown"]}]}]},
           "offer": ["pray"]}
        ],
        "reduce": {
          "chant": {"seq": [
            {"let": ["roll", {"rollDie": [6]},
              "drm", {"totalChantDRM": []},
              {"seq": [
                {"set": ["lastDieRoll", "$roll"]},
                {"if": [{"and": [{"!=": ["$roll", 1]},
                                  {">": [{"+": ["$roll", "$drm"]}, 3]}]},
                  {"seq": [
                    {"set": ["divineEnergy", {"min": [6, {"+": ["divineEnergy", 1]}]}]},
                    {"log": [{"format": ["Chant succeeded: rolled {} + {} DRM", "$roll", "$drm"]}]}
                  ]},
                  {"log": [{"format": ["Chant failed: rolled {} + {} DRM", "$roll", "$drm"]}]}
                ]},
                {"increment": ["actionPointsSpent", 1]}
              ]}
            ]}
          ]},
          "memorize": {"seq": [
            {"memorizeRandomArcane": []},
            {"increment": ["actionPointsSpent", 1]},
            {"log": ["Memorize: revealed a random arcane spell"]}
          ]},
          "pray": {"seq": [
            {"prayRandomDivine": []},
            {"increment": ["actionPointsSpent", 1]},
            {"log": ["Pray: revealed a random divine spell"]}
          ]}
        }
      },

      // ── Spell Pages ────────────────────────────────────────────
      // Fireball (arcane, cost 1): +2 ranged magical attack
      {
        "page": "Fireball",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []},
                             {"canCastSpell": ["fireball", "wizard", "arcaneEnergy", 1]}]},
           "offer": ["castFireball"],
           "paramFilter": {"and": [{"slotMatchesHeroLocation": ["$slot", "wizard"]},
                                    {"armyOnTrack": ["$slot"]}]}},
          // Heroic: reroll on miss, wizard must be alive
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeHeroicAction": []},
                             {"canCastSpell": ["fireball", "wizard", "arcaneEnergy", 1]}]},
           "offer": ["castFireballHeroic"],
           "paramFilter": {"and": [{"slotMatchesHeroLocation": ["$slot", "wizard"]},
                                    {"armyOnTrack": ["$slot"]}]}}
        ],
        "reduce": {
          "castFireball": {"seq": [
            {"set": ["arcaneEnergy", {"-": ["arcaneEnergy", 1]}]},
            {"setEntry": ["spellStatusDict", "fireball", ".cast"]},
            {"let": ["roll", {"rollDie": [6]},
              "strength", {"lookup": ["armyStrengthDict", "$slot"]},
              "drm", {"spellAttackDRM": [2]},
              {"seq": [
                {"resolveAttackRoll": ["$roll", "$drm", "$strength", "$slot"]},
                {"log": [{"format": ["Fireball on {}: rolled {} + {} vs {}", "$slot", "$roll", "$drm", "$strength"]}]}
              ]}
            ]},
            {"increment": ["actionPointsSpent", 1]}
          ]},
          "castFireballHeroic": {"seq": [
            {"set": ["arcaneEnergy", {"-": ["arcaneEnergy", 1]}]},
            {"setEntry": ["spellStatusDict", "fireball", ".cast"]},
            {"let": ["roll", {"rollDie": [6]},
              "strength", {"lookup": ["armyStrengthDict", "$slot"]},
              "drm", {"spellAttackDRM": [2]},
              {"seq": [
                {"if": [{"and": [{"!=": ["$roll", 1]},
                                  {">": [{"+": ["$roll", "$drm"]}, "$strength"]}]},
                  {"pushBackArmy": ["$slot"]},
                  // Miss — heroic reroll
                  {"let": ["reroll", {"rollDie": [6]},
                    {"seq": [
                      {"resolveAttackRoll": ["$reroll", "$drm", "$strength", "$slot"]},
                      {"log": [{"format": ["Fireball heroic reroll on {}: rolled {}", "$slot", "$reroll"]}]}
                    ]}
                  ]}
                ]},
                {"log": [{"format": ["Fireball heroic on {}: rolled {} + {} vs {}",
                  "$slot", "$roll", "$drm", "$strength"]}]}
              ]}
            ]},
            {"increment": ["heroicPointsSpent", 1]}
          ]}
        }
      },

      // Slow (arcane, cost 2): place slow marker. Heroic: retreat first.
      {
        "page": "Slow",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []},
                             {"canCastSpell": ["slow", "wizard", "arcaneEnergy", 2]}]},
           "offer": ["castSlowNormal"],
           "paramFilter": {"and": [{"slotMatchesHeroLocation": ["$slot", "wizard"]},
                                    {"armyOnTrack": ["$slot"]}]}},
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeHeroicAction": []},
                             {"canCastSpell": ["slow", "wizard", "arcaneEnergy", 2]}]},
           "offer": ["castSlowHeroic"],
           "paramFilter": {"and": [{"slotMatchesHeroLocation": ["$slot", "wizard"]},
                                    {"armyOnTrack": ["$slot"]}]}}
        ],
        "reduce": {
          "castSlowNormal": {"seq": [
            {"set": ["arcaneEnergy", {"-": ["arcaneEnergy", 2]}]},
            {"setEntry": ["spellStatusDict", "slow", ".cast"]},
            {"set": ["slowedArmy", "$slot"]},
            {"log": [{"format": ["Slow placed on {}", "$slot"]}]},
            {"increment": ["actionPointsSpent", 1]}
          ]},
          "castSlowHeroic": {"seq": [
            {"set": ["arcaneEnergy", {"-": ["arcaneEnergy", 2]}]},
            {"setEntry": ["spellStatusDict", "slow", ".cast"]},
            // Heroic: retreat army one space first
            {"pushBackArmy": ["$slot"]},
            {"set": ["slowedArmy", "$slot"]},
            {"log": [{"format": ["Slow (heroic) placed on {} after retreat", "$slot"]}]},
            {"increment": ["heroicPointsSpent", 1]}
          ]}
        }
      },

      // Cure Wounds (divine, cost 1): heal wounded heroes
      {
        "page": "Cure Wounds",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []},
                             {"canCastSpell": ["cureWounds", "cleric", "divineEnergy", 1]}]},
           "offer": ["castCureWoundsNormal"]},
          // Heroic: heal 2 heroes, costs heroic point, cleric must be alive
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeHeroicAction": []},
                             {"canCastSpell": ["cureWounds", "cleric", "divineEnergy", 1]}]},
           "offer": ["castCureWoundsHeroic"]}
        ],
        "reduce": {
          "castCureWoundsNormal": {"seq": [
            {"set": ["divineEnergy", {"-": ["divineEnergy", 1]}]},
            {"setEntry": ["spellStatusDict", "cureWounds", ".cast"]},
            {"removeFrom": ["heroWounded", "$hero"]},
            {"log": [{"format": ["Cure Wounds: healed {}", "$hero"]}]},
            {"increment": ["actionPointsSpent", 1]}
          ]},
          "castCureWoundsHeroic": {"seq": [
            {"set": ["divineEnergy", {"-": ["divineEnergy", 1]}]},
            {"setEntry": ["spellStatusDict", "cureWounds", ".cast"]},
            {"removeFrom": ["heroWounded", "$hero1"]},
            {"removeFrom": ["heroWounded", "$hero2"]},
            {"log": [{"format": ["Cure Wounds (heroic): healed {} and {}", "$hero1", "$hero2"]}]},
            {"increment": ["heroicPointsSpent", 1]}
          ]}
        }
      },

      // Mass Heal (divine, cost 2): gain defenders
      {
        "page": "Mass Heal",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []},
                             {"canCastSpell": ["massHeal", "cleric", "divineEnergy", 2]}]},
           "offer": ["castMassHealNormal"]},
          // Heroic: gain 2 different defenders, cleric must be alive
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeHeroicAction": []},
                             {"canCastSpell": ["massHeal", "cleric", "divineEnergy", 2]}]},
           "offer": ["castMassHealHeroic"]}
        ],
        "reduce": {
          "castMassHealNormal": {"seq": [
            {"set": ["divineEnergy", {"-": ["divineEnergy", 2]}]},
            {"setEntry": ["spellStatusDict", "massHeal", ".cast"]},
            {"gainDefender": ["$defType"]},
            {"log": [{"format": ["Mass Heal: +1 {}", "$defType"]}]},
            {"increment": ["actionPointsSpent", 1]}
          ]},
          "castMassHealHeroic": {"seq": [
            {"set": ["divineEnergy", {"-": ["divineEnergy", 2]}]},
            {"setEntry": ["spellStatusDict", "massHeal", ".cast"]},
            {"gainDefender": ["$def1"]},
            {"gainDefender": ["$def2"]},
            {"log": [{"format": ["Mass Heal (heroic): +1 {} and +1 {}", "$def1", "$def2"]}]},
            {"increment": ["heroicPointsSpent", 1]}
          ]}
        }
      },

      // Inspire (divine, cost 3): normal = raise morale only; heroic = raise morale + DRM
      {
        "page": "Inspire",
        "rules": [
          // Normal: only offered if morale < high (morale raise is the only effect)
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []},
                             {"canCastSpell": ["inspire", "cleric", "divineEnergy", 3]},
                             {"!=": ["morale", ".high"]}]},
           "offer": ["castInspireNormal"]},
          // Heroic: always available (DRM is valuable regardless of morale)
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeHeroicAction": []},
                             {"canCastSpell": ["inspire", "cleric", "divineEnergy", 3]}]},
           "offer": ["castInspireHeroic"]}
        ],
        "reduce": {
          "castInspireNormal": {"seq": [
            {"set": ["divineEnergy", {"-": ["divineEnergy", 3]}]},
            {"setEntry": ["spellStatusDict", "inspire", ".cast"]},
            {"raiseMorale": []},
            {"log": ["Inspire: morale raised"]},
            {"increment": ["actionPointsSpent", 1]}
          ]},
          "castInspireHeroic": {"seq": [
            {"set": ["divineEnergy", {"-": ["divineEnergy", 3]}]},
            {"setEntry": ["spellStatusDict", "inspire", ".cast"]},
            {"raiseMorale": []},
            {"set": ["inspireDRMActive", true]},
            {"log": ["Inspire (heroic): morale raised, +1 DRM active"]},
            {"increment": ["heroicPointsSpent", 1]}
          ]}
        }
      },

      // Divine Wrath (divine, cost 3): magical attack with +1, undead retreat bonus
      {
        "page": "Divine Wrath",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []},
                             {"canCastSpell": ["divineWrath", "cleric", "divineEnergy", 3]}]},
           "offer": ["castDivineWrathNormal"],
           "paramFilter": {"and": [{"slotMatchesHeroLocation": ["$slot", "cleric"]},
                                    {"armyOnTrack": ["$slot"]}]}},
          // Heroic: two +1 attacks on (possibly different) slots, cleric must be alive
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeHeroicAction": []},
                             {"canCastSpell": ["divineWrath", "cleric", "divineEnergy", 3]}]},
           "offer": ["castDivineWrathHeroic"],
           "paramFilter": {"and": [{"!=": ["$slot1", "$slot2"]},
                                    {"slotMatchesHeroLocation": ["$slot1", "cleric"]},
                                    {"slotMatchesHeroLocation": ["$slot2", "cleric"]},
                                    {"armyOnTrack": ["$slot1"]},
                                    {"armyOnTrack": ["$slot2"]}]}}
        ],
        "reduce": {
          "castDivineWrathNormal": {"seq": [
            {"set": ["divineEnergy", {"-": ["divineEnergy", 3]}]},
            {"setEntry": ["spellStatusDict", "divineWrath", ".cast"]},
            {"let": ["roll", {"rollDie": [6]},
              "strength", {"lookup": ["armyStrengthDict", "$slot"]},
              "drm", {"spellAttackDRM": [1]},
              {"seq": [
                {"resolveAttackRoll": ["$roll", "$drm", "$strength", "$slot"]},
                {"log": [{"format": ["Divine Wrath on {}: rolled {} + {}", "$slot", "$roll", "$drm"]}]}
              ]}
            ]},
            {"increment": ["actionPointsSpent", 1]}
          ]},
          "castDivineWrathHeroic": {"seq": [
            {"set": ["divineEnergy", {"-": ["divineEnergy", 3]}]},
            {"setEntry": ["spellStatusDict", "divineWrath", ".cast"]},
            // Attack slot1
            {"let": ["roll1", {"rollDie": [6]},
              "str1", {"lookup": ["armyStrengthDict", "$slot1"]},
              "drm", {"spellAttackDRM": [1]},
              {"seq": [
                {"resolveAttackRoll": ["$roll1", "$drm", "$str1", "$slot1"]},
                {"log": [{"format": ["Divine Wrath heroic on {}: rolled {} + {}", "$slot1", "$roll1", "$drm"]}]}
              ]}
            ]},
            // Attack slot2
            {"let": ["roll2", {"rollDie": [6]},
              "str2", {"lookup": ["armyStrengthDict", "$slot2"]},
              "drm2", {"spellAttackDRM": [1]},
              {"seq": [
                {"resolveAttackRoll": ["$roll2", "$drm2", "$str2", "$slot2"]},
                {"log": [{"format": ["Divine Wrath heroic on {}: rolled {} + {}", "$slot2", "$roll2", "$drm2"]}]}
              ]}
            ]},
            {"increment": ["heroicPointsSpent", 1]}
          ]}
        }
      },

      // Raise Dead (divine, cost 4): gain defenders or return hero
      {
        "page": "Raise Dead",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []},
                             {"canCastSpell": ["raiseDead", "cleric", "divineEnergy", 4]}]},
           "offer": ["castRaiseDeadDefenders", "castRaiseDeadHero"]},
          // Heroic: gain defenders AND return hero, cleric must be alive
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeHeroicAction": []},
                             {"canCastSpell": ["raiseDead", "cleric", "divineEnergy", 4]}]},
           "offer": ["castRaiseDeadHeroicBoth"]}
        ],
        "reduce": {
          "castRaiseDeadDefenders": {"seq": [
            {"set": ["divineEnergy", {"-": ["divineEnergy", 4]}]},
            {"setEntry": ["spellStatusDict", "raiseDead", ".cast"]},
            {"gainDefender": ["$def1"]},
            {"gainDefender": ["$def2"]},
            {"log": [{"format": ["Raise Dead: +1 {} and +1 {}", "$def1", "$def2"]}]},
            {"increment": ["actionPointsSpent", 1]}
          ]},
          "castRaiseDeadHero": {"seq": [
            {"set": ["divineEnergy", {"-": ["divineEnergy", 4]}]},
            {"setEntry": ["spellStatusDict", "raiseDead", ".cast"]},
            {"removeFrom": ["heroDead", "$hero"]},
            {"setEntry": ["heroLocationDict", "$hero", ".reserves"]},
            {"log": [{"format": ["Raise Dead: returned {} to reserves", "$hero"]}]},
            {"increment": ["actionPointsSpent", 1]}
          ]},
          "castRaiseDeadHeroicBoth": {"seq": [
            {"set": ["divineEnergy", {"-": ["divineEnergy", 4]}]},
            {"setEntry": ["spellStatusDict", "raiseDead", ".cast"]},
            {"gainDefender": ["$def1"]},
            {"gainDefender": ["$def2"]},
            {"removeFrom": ["heroDead", "$hero"]},
            {"setEntry": ["heroLocationDict", "$hero", ".reserves"]},
            {"log": [{"format": ["Raise Dead (heroic): +1 {}, +1 {}, {} returned",
              "$def1", "$def2", "$hero"]}]},
            {"increment": ["heroicPointsSpent", 1]}
          ]}
        }
      },

      // Chain Lightning (arcane, cost 3): initiate 3-bolt sequence
      {
        "page": "Cast Chain Lightning",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []},
                             {"canCastSpell": ["chainLightning", "wizard", "arcaneEnergy", 3]}]},
           "offer": ["castChainLightningNormal"]},
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeHeroicAction": []},
                             {"canCastSpell": ["chainLightning", "wizard", "arcaneEnergy", 3]}]},
           "offer": ["castChainLightningHeroic"]}
        ],
        "reduce": {
          "castChainLightningNormal": {"seq": [
            {"set": ["arcaneEnergy", {"-": ["arcaneEnergy", 3]}]},
            {"setEntry": ["spellStatusDict", "chainLightning", ".cast"]},
            {"set": ["inChainLightning", true]},
            {"set": ["chainLightningHeroic", false]},
            {"set": ["chainLightningBoltIndex", 0]},
            {"increment": ["actionPointsSpent", 1]},
            {"log": ["Chain Lightning: choose bolt targets"]}
          ]},
          "castChainLightningHeroic": {"seq": [
            {"set": ["arcaneEnergy", {"-": ["arcaneEnergy", 3]}]},
            {"setEntry": ["spellStatusDict", "chainLightning", ".cast"]},
            {"set": ["inChainLightning", true]},
            {"set": ["chainLightningHeroic", true]},
            {"set": ["chainLightningBoltIndex", 0]},
            {"increment": ["heroicPointsSpent", 1]},
            {"log": ["Chain Lightning (heroic): choose bolt targets"]}
          ]}
        }
      },

      // Chain Lightning targeting sub-resolution
      {
        "page": "Chain Lightning",
        "rules": [
          {"when": {"and": ["inChainLightning",
                             {"<": ["chainLightningBoltIndex", 3]}]},
           "offer": ["lightningBolt"],
           "paramFilter": {"and": [{"!=": [{"lookup": ["armyPosition", "$slot"]}, null]},
                                    {"<": [{"lookup": ["armyPosition", "$slot"]}, {"slotMaxSpace": ["$slot"]}]}]}}
        ],
        "reduce": {
          "lightningBolt": {"let": [
            "roll", {"rollDie": [6]},
            "strength", {"lookup": ["armyStrengthDict", "$slot"]},
            "baseDRM", {"if": ["chainLightningHeroic",
              {"-": [3, "chainLightningBoltIndex"]},
              {"-": [2, "chainLightningBoltIndex"]}]},
            "drm", {"spellAttackDRM": ["$baseDRM"]},
            {"seq": [
              {"resolveAttackRoll": ["$roll", "$drm", "$strength", "$slot"]},
              {"increment": ["chainLightningBoltIndex", 1]},
              {"log": [{"format": ["Lightning bolt {}: rolled {} + {} vs {}",
                "chainLightningBoltIndex", "$roll", "$drm", "$strength"]}]},
              {"if": [{">=": ["chainLightningBoltIndex", 3]},
                {"seq": [
                  {"set": ["inChainLightning", false]},
                  {"log": ["Chain Lightning complete"]}
                ]},
                {"log": ["Choose next bolt target"]}
              ]}
            ]}
          ]}
        }
      },

      // Fortune (arcane, cost 4): peek at deck
      {
        "page": "Cast Fortune",
        "rules": [
          // Normal Fortune doesn't require wizard — just spell known + energy
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []},
                             {"==": [{"lookup": ["spellStatusDict", "fortune"]}, ".known"]},
                             {">=": ["arcaneEnergy", 4]}]},
           "offer": ["castFortuneNormal"]},
          // Heroic Fortune requires wizard alive
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeHeroicAction": []},
                             {"canCastSpell": ["fortune", "wizard", "arcaneEnergy", 4]}]},
           "offer": ["castFortuneHeroic"]}
        ],
        "reduce": {
          "castFortuneNormal": {"seq": [
            {"set": ["arcaneEnergy", {"-": ["arcaneEnergy", 4]}]},
            {"setEntry": ["spellStatusDict", "fortune", ".cast"]},
            {"set": ["inFortune", true]},
            {"set": ["fortuneHeroic", false]},
            {"set": ["fortuneDiscardDone", true]},
            {"increment": ["actionPointsSpent", 1]},
            {"log": ["Fortune: viewing top cards"]}
          ]},
          "castFortuneHeroic": {"seq": [
            {"set": ["arcaneEnergy", {"-": ["arcaneEnergy", 4]}]},
            {"setEntry": ["spellStatusDict", "fortune", ".cast"]},
            {"set": ["inFortune", true]},
            {"set": ["fortuneHeroic", true]},
            {"set": ["fortuneDiscardDone", false]},
            {"increment": ["heroicPointsSpent", 1]},
            {"log": ["Fortune (heroic): viewing top cards, may discard"]}
          ]}
        }
      },

      // Fortune sub-resolution: discard (heroic) then reorder
      {
        "page": "Fortune",
        "rules": [
          // Heroic discard phase
          {"when": {"and": ["inFortune", "fortuneHeroic", {"not": ["fortuneDiscardDone"]}]},
           "offer": ["fortuneDiscard", "fortuneSkipDiscard"]},
          // Reorder phase
          {"when": {"and": ["inFortune", "fortuneDiscardDone"]},
           "offer": ["fortuneReorder"]}
        ],
        "reduce": {
          "fortuneDiscard": {"seq": [
            // Discard card at index from current deck's top
            {"set": ["fortuneDiscardDone", true]},
            {"log": [{"format": ["Fortune: discarded card at index {}", "$index"]}]}
          ]},
          "fortuneSkipDiscard": {"seq": [
            {"set": ["fortuneDiscardDone", true]},
            {"log": ["Fortune: keeping all cards"]}
          ]},
          "fortuneReorder": {"seq": [
            // Apply reorder to deck top (simplified — order param is an index)
            {"set": ["inFortune", false]},
            {"log": ["Fortune: deck reordered"]}
          ]}
        }
      },

      // ── Heroic Page ────────────────────────────────────────────
      {
        "page": "Heroic",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeHeroicAction": []}]},
           "offer": ["moveHero"],
           "paramFilter": {"and": [
             {"heroAlive": ["$hero"]},
             {"!=": ["$location", {"lookup": ["heroLocationDict", "$hero"]}]}]}},
          // Heroic attack: hero must be on a track (not reserves/dead) with army present
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeHeroicAction": []}]},
           "offer": ["heroicAttack"],
           "paramFilter": {"and": [
             {"heroAlive": ["$hero"]},
             {"!=": [{"lookup": ["heroLocationDict", "$hero"]}, ".reserves"]},
             {"armyOnTrack": ["$slot"]},
             {"slotMatchesHeroLocation": ["$slot", "$hero"]}]}},
          // Rally: always available with heroic budget
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeHeroicAction": []}]},
           "offer": ["rally"]}
        ],
        "reduce": {
          "moveHero": {"seq": [
            {"setEntry": ["heroLocationDict", "$hero", "$location"]},
            {"increment": ["heroicPointsSpent", 1]},
            {"log": [{"format": ["Hero {} moved to {}", "$hero", "$location"]}]}
          ]},
          "heroicAttack": {"initiateHeroicAttack": ["$hero", "$slot"]},
          "rally": {"initiateRally": []}
        }
      },

      // ── Quest Page ─────────────────────────────────────────────
      {
        "page": "Quest",
        "rules": [
          // Rule 5.7: quest attempt once per turn — questAction requires action budget
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeAction": []},
                             {"!=": [{"get": ["currentCard", "questNumber"]}, 0]},
                             {"not": ["questAttemptedThisTurn"]}]},
           "offer": ["questAction"],
           "paramFilter": {"<=": ["$points", {"actionBudgetRemaining": []}]}},
          // questHeroic requires heroic budget
          {"when": {"and": [{"==": ["phase", ".action"]}, {"canTakeHeroicAction": []},
                             {"!=": [{"get": ["currentCard", "questNumber"]}, 0]},
                             {"not": ["questAttemptedThisTurn"]}]},
           "offer": ["questHeroic"],
           "paramFilter": {"<=": ["$points", {"heroicBudgetRemaining": []}]}}
        ],
        "reduce": {
          "questAction": {"seq": [
            {"set": ["questAttemptedThisTurn", true]},
            {"let": ["roll", {"rollDie": [6]},
              "target", {"get": ["currentCard", "questTarget"]},
              "drm", {"+": ["$points", {"questDRM": []}]},
              {"seq": [
                {"if": [{"and": [{"!=": ["$roll", 1]},
                                  {">": [{"+": ["$roll", "$drm"]}, "$target"]}]},
                  {"seq": [
                    {"resolveQuestReward": []},
                    {"log": [{"format": ["Quest succeeded: rolled {} + {} vs {}",
                      "$roll", "$drm", "$target"]}]}
                  ]},
                  {"log": [{"format": ["Quest failed: rolled {} + {} vs {}",
                    "$roll", "$drm", "$target"]}]}
                ]}
              ]}
            ]},
            {"increment": ["actionPointsSpent", "$points"]}
          ]},
          "questHeroic": {"seq": [
            {"set": ["questAttemptedThisTurn", true]},
            {"let": ["roll", {"rollDie": [6]},
              "target", {"get": ["currentCard", "questTarget"]},
              "drm", {"+": [{"*": ["$points", 2]}, {"questDRM": []}]},
              {"seq": [
                {"if": [{"and": [{"!=": ["$roll", 1]},
                                  {">": [{"+": ["$roll", "$drm"]}, "$target"]}]},
                  {"seq": [
                    {"resolveQuestReward": []},
                    {"log": [{"format": ["Quest (heroic) succeeded: rolled {} + {} vs {}",
                      "$roll", "$drm", "$target"]}]}
                  ]},
                  {"log": [{"format": ["Quest (heroic) failed: rolled {} + {} vs {}",
                    "$roll", "$drm", "$target"]}]}
                ]}
              ]}
            ]},
            {"increment": ["heroicPointsSpent", "$points"]}
          ]}
        }
      },

      // ── Quest Reward Pages ─────────────────────────────────────
      // Card 2: Scrolls of the Dead — choose a spell to learn
      {
        "page": "Scrolls of the Dead",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".action"]},
                             "questRewardPending",
                             {"==": [{"get": ["currentCard", "questNumber"]}, 2]}]},
           "offer": ["scrollsOfTheDead"]}
        ],
        "reduce": {
          "scrollsOfTheDead": {"seq": [
            {"setEntry": ["spellStatusDict", "$spell", ".known"]},
            {"set": ["questRewardPending", false]},
            {"log": [{"format": ["Quest reward: learned {}", "$spell"]}]}
          ]}
        }
      },

      // Card 10: Put Forth the Call — choose a defender to gain
      {
        "page": "Put Forth the Call",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".action"]},
                             "questRewardPending",
                             {"==": [{"get": ["currentCard", "questNumber"]}, 10]}]},
           "offer": ["putForthTheCall"]}
        ],
        "reduce": {
          "putForthTheCall": {"seq": [
            {"gainDefender": ["$defType"]},
            {"set": ["questRewardPending", false]},
            {"log": [{"format": ["Quest reward: +1 {}", "$defType"]}]}
          ]}
        }
      },

      // Card 15: Last Ditch Efforts — add unselected hero
      {
        "page": "Last Ditch Efforts",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".action"]},
                             "questRewardPending",
                             {"==": [{"get": ["currentCard", "questNumber"]}, 15]}]},
           "offer": ["lastDitchEfforts"]}
        ],
        "reduce": {
          "lastDitchEfforts": {"seq": [
            {"setEntry": ["heroLocationDict", "$hero", ".reserves"]},
            {"set": ["questRewardPending", false]},
            {"log": [{"format": ["Quest reward: added {} to reserves", "$hero"]}]}
          ]}
        }
      },

      // Card 22: Pillars of the Earth — retreat one army 2 spaces
      {
        "page": "Pillars of the Earth",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".action"]},
                             "questRewardPending",
                             {"==": [{"get": ["currentCard", "questNumber"]}, 22]}]},
           "offer": ["pillarsOfTheEarth"]}
        ],
        "reduce": {
          "pillarsOfTheEarth": {"seq": [
            // Retreat army 2 spaces (not Sky)
            {"pushBackArmy": ["$slot"]},
            {"pushBackArmy": ["$slot"]},
            {"set": ["questRewardPending", false]},
            {"log": [{"format": ["Quest reward: retreated {} 2 spaces", "$slot"]}]}
          ]}
        }
      },

      // Card 28: Prophecy Revealed — discard 1 of top 3 day cards
      {
        "page": "Prophecy Revealed",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".action"]},
                             "questRewardPending",
                             {"==": [{"get": ["currentCard", "questNumber"]}, 28]}]},
           "offer": ["prophecyRevealed"]}
        ],
        "reduce": {
          "prophecyRevealed": {"seq": [
            // Remove card at discardIndex from top of day deck
            {"removeAt": ["dayDeck", "$discardIndex"]},
            {"set": ["questRewardPending", false]},
            {"log": ["Quest reward: Prophecy Revealed"]}
          ]}
        }
      },

      // ── Acid Free Attack ───────────────────────────────────────
      {
        "page": "Acid Attack",
        "rules": [
          // Rule 6.3.2: free melee attack against an army in the 1 space of a track with acid
          {"when": {"and": [{"==": ["phase", ".action"]}, {"inActionPhase": []},
                             {"not": ["acidUsedThisTurn"]},
                             {"anyAcidEligible": []}]},
           "offer": ["acidMeleeAttack"],
           "paramFilter": {"and": [{"==": [{"lookup": ["upgradeDict", "$slot"]}, ".acid"]},
                                    {"==": [{"lookup": ["armyPosition", "$slot"]}, 1]}]}}
        ],
        "reduce": {
          "acidMeleeAttack": {"seq": [
            {"let": ["roll", {"rollDie": [6]},
              "strength", {"lookup": ["armyStrengthDict", "$slot"]},
              {"seq": [
                {"resolveAttackRoll": ["$roll", 0, "$strength", "$slot"]},
                {"log": [{"format": ["Acid free attack on {}: rolled {} vs {}",
                  "$slot", "$roll", "$strength"]}]}
              ]}
            ]},
            {"set": ["acidUsedThisTurn", true]}
          ]}
        }
      },

      // ── General Page (Rogue Move, End Turn) ────────────────────
      {
        "page": "General",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".action"]}, {"inActionPhase": []},
                             {"heroAlive": ["rogue"]}]},
           "offer": ["rogueMove"]},
          {"when": {"and": [{"==": ["phase", ".action"]}, {"inActionPhase": []}]},
           "offer": ["endPlayerTurn"]}
        ],
        "reduce": {
          "rogueMove": {"seq": [
            {"setEntry": ["heroLocationDict", "rogue", "$location"]},
            {"log": [{"format": ["Rogue moved to {} (free)", "$location"]}]}
          ]},
          "endPlayerTurn": {"seq": [
            {"log": ["Player turn ended"]},
            {"chain": ["performHousekeeping"]}
          ]}
        }
      },

      // ── Paladin React ──────────────────────────────────────────
      {
        "page": "Paladin React",
        "rules": [
          {"when": {"and": [{"==": ["phase", ".paladinReact"]},
                             {"!=": ["pendingRoll", ".none"]}]},
           "offer": ["paladinReroll", "declineReroll"]}
        ],
        "reduce": {
          "paladinReroll": {"seq": [
            {"set": ["lastDieRoll", {"rollDie": [6]}]},
            {"set": ["paladinRerollUsed", true]},
            {"log": [{"format": ["Paladin re-roll: new die = {}", "lastDieRoll"]}]},
            {"resolvePendingRoll": []},
            {"set": ["pendingRoll", ".none"]},
            {"setPhase": [".action"]}
          ]},
          "declineReroll": {"seq": [
            {"log": ["Declined re-roll"]},
            {"resolvePendingRoll": []},
            {"set": ["pendingRoll", ".none"]},
            {"setPhase": [".action"]}
          ]}
        }
      },

      // ── Housekeeping ───────────────────────────────────────────
      {
        "page": "Housekeeping",
        "rules": [],
        "reduce": {
          "performHousekeeping": {"let": [
            // Save deck source BEFORE advancing time, so card is discarded
            // to the deck it was drawn from (not the deck for the new time).
            "wasDayDeck", {"drawsFromDayDeck": []},
            {"seq": [
              // Advance time by card's time value
              {"advanceTime": [{"get": ["currentCard", "time"]}]},
              // Reset per-turn tracking
              {"set": ["bloodyBattlePaidThisTurn", false]},
              {"set": ["acidUsedThisTurn", false]},
              {"set": ["paladinRerollUsed", false]},
              {"set": ["inspireDRMActive", false]},
              {"set": ["eventAttackDRMBonus", 0]},
              {"set": ["noMeleeThisTurn", false]},
              {"set": ["woundedHeroesCannotAct", false]},
              {"set": ["snapshotTaken", false]},
              {"set": ["snapshotActionBudget", 0]},
              {"set": ["questAttemptedThisTurn", false]},
              {"set": ["questPenaltyAppliedThisTurn", false]},
              {"set": ["questRewardPending", false]},
              {"set": ["defenderLossesPending", 0]},
              {"set": ["actionPointsSpent", 0]},
              {"set": ["heroicPointsSpent", 0]},
              {"set": ["meleeAttacksThisTurn", 0]},
              {"set": ["rangedAttacksThisTurn", 0]},
              {"removeFrom": ["acidEligibleSlots", "east"]},
              {"removeFrom": ["acidEligibleSlots", "west"]},
              {"removeFrom": ["acidEligibleSlots", "gate1"]},
              {"removeFrom": ["acidEligibleSlots", "gate2"]},
              {"removeFrom": ["acidEligibleSlots", "sky"]},
              {"removeFrom": ["acidEligibleSlots", "terror"]},
              // Check victory on Final Twilight
              {"if": [{">=": ["timePosition", 15]},
                {"seq": [
                  {"set": ["ended", true]},
                  {"set": ["victory", true]},
                  {"log": ["Final Twilight — Victory!"]}
                ]},
                {"log": [{"format": ["Housekeeping complete. Time: {}", "timePosition"]}]}
              ]},
              // Discard current card to the deck it was drawn from
              {"if": [{"!=": ["currentCard", null]},
                {"if": ["$wasDayDeck",
                  {"discard": ["currentCard", "dayDeck"]},
                  {"discard": ["currentCard", "nightDeck"]}
                ]},
                {"log": ["No card to discard"]}
              ]},
              // Transition to card phase
              {"setPhase": [".card"]}
            ]}
          ]}
        }
      }
    ],

    // ── Priorities ─────────────────────────────────────────────
    "priorities": [
      {
        "priority": "Victory",
        "rules": [
          {"when": {"and": ["ended", "victory"]},
           "offer": ["claimVictory"]}
        ],
        "reduce": {
          "claimVictory": {"seq": [
            {"set": ["gameAcknowledged", true]},
            {"log": ["Victory! The castle stands!"]}
          ]}
        }
      },
      {
        "priority": "Defeat",
        "rules": [
          {"when": {"and": ["ended", {"not": ["victory"]}]},
           "offer": ["declareLoss"]}
        ],
        "reduce": {
          "declareLoss": {"seq": [
            {"set": ["gameAcknowledged", true]},
            {"log": ["Defeat! The castle has fallen."]}
          ]}
        }
      },
      {
        "priority": "Defender Choice",
        "rules": [
          {"when": {"and": [{">": ["defenderLossesPending", 0]},
                            {"<": [{"lookup": ["defenderPosition", "archers"]}, 4]}]},
           "offer": ["loseDefenderArchers"]},
          {"when": {"and": [{">": ["defenderLossesPending", 0]},
                            {"<": [{"lookup": ["defenderPosition", "menAtArms"]}, 5]}]},
           "offer": ["loseDefenderMenAtArms"]},
          {"when": {"and": [{">": ["defenderLossesPending", 0]},
                            {"<": [{"lookup": ["defenderPosition", "priests"]}, 3]}]},
           "offer": ["loseDefenderPriests"]},
          // Fallback: all defenders at max — clear pending without losing anyone
          {"when": {"and": [{">": ["defenderLossesPending", 0]},
                            {">=": [{"lookup": ["defenderPosition", "archers"]}, 4]},
                            {">=": [{"lookup": ["defenderPosition", "menAtArms"]}, 5]},
                            {">=": [{"lookup": ["defenderPosition", "priests"]}, 3]}]},
           "offer": ["loseDefenderNoneAvailable"]}
        ],
        "reduce": {
          "loseDefenderArchers": {"seq": [
            {"loseDefender": ["archers"]},
            {"increment": ["defenderLossesPending", -1]},
            {"log": ["Player chose to lose an archer"]}
          ]},
          "loseDefenderMenAtArms": {"seq": [
            {"loseDefender": ["menAtArms"]},
            {"increment": ["defenderLossesPending", -1]},
            {"log": ["Player chose to lose a man-at-arms"]}
          ]},
          "loseDefenderPriests": {"seq": [
            {"loseDefender": ["priests"]},
            {"increment": ["defenderLossesPending", -1]},
            {"log": ["Player chose to lose a priest"]}
          ]},
          "loseDefenderNoneAvailable": {"seq": [
            {"increment": ["defenderLossesPending", -1]},
            {"log": ["All defenders at maximum losses — no choice to make"]}
          ]}
        }
      }
    ],

    // ── Reactions (auto-rules) ─────────────────────────────────
    "reactions": [
      // Snapshot action budget at start of action phase
      {
        "reaction": "snapshotActionBudget",
        "when": {"and": [{"==": ["phase", ".action"]}, {"not": ["snapshotTaken"]}]},
        "apply": {"seq": [
          {"set": ["snapshotActionBudget", {"actionBudget": []}]},
          {"set": ["snapshotTaken", true]}
        ]}
      },
      // Check all defenders at zero => defeat
      {
        "reaction": "checkAllDefendersZero",
        "when": {"and": [
          {"not": ["ended"]},
          {"allDefendersAtZero": []}
        ]},
        "apply": {"seq": [
          {"set": ["ended", true]},
          {"log": ["All defenders at zero — defeat!"]}
        ]}
      }
    ]
  },

  // ═══════════════════════════════════════════════════════════════
  // DEFINES
  // ═══════════════════════════════════════════════════════════════
  "defines": [
    // ── Predicate defines ──────────────────────────────────────
    {"name": "heroAlive",
     "params": ["hero"],
     "body": {"and": [{"!=": [{"lookup": ["heroLocationDict", "$hero"]}, null]},
                       {"not": [{"contains": ["heroDead", "$hero"]}]}]}},

    {"name": "isEventCard",
     "params": ["eventNumber"],
     "body": {"and": [{"==": ["phase", ".event"]},
                       {"==": [{"get": ["currentCard", "eventNumber"]}, "$eventNumber"]}]}},

    {"name": "inActionPhase",
     "params": [],
     "body": {"and": [{"==": ["phase", ".action"]},
                       {"not": ["inChainLightning"]},
                       {"not": ["inDeathAndDespair"]},
                       {"not": ["inFortune"]},
                       {"not": ["questRewardPending"]}]}},

    {"name": "canTakeAction",
     "params": [],
     "body": {"and": [{"==": ["phase", ".action"]},
                       {">": [{"actionBudgetRemaining": []}, 0]},
                       {"not": ["inChainLightning"]},
                       {"not": ["inDeathAndDespair"]},
                       {"not": ["inFortune"]},
                       {"not": ["questRewardPending"]}]}},

    {"name": "canTakeHeroicAction",
     "params": [],
     "body": {"and": [{"==": ["phase", ".action"]},
                       {">": [{"heroicBudgetRemaining": []}, 0]},
                       {"not": ["inChainLightning"]},
                       {"not": ["inDeathAndDespair"]},
                       {"not": ["inFortune"]},
                       {"not": ["questRewardPending"]}]}},

    {"name": "armyOnTrack",
     "params": ["slot"],
     "body": {"and": [{"!=": [{"lookup": ["armyPosition", "$slot"]}, null]},
                       {"<": [{"lookup": ["armyPosition", "$slot"]}, {"slotMaxSpace": ["$slot"]}]}]}},

    {"name": "gateTieBreak",
     "params": ["slot"],
     "body": {"or": [
       {"and": [{"!=": ["$slot", "gate1"]}, {"!=": ["$slot", "gate2"]}]},
       {"and": [{"==": ["$slot", "gate1"]},
                {"or": [{"==": [{"lookup": ["armyPosition", "gate2"]}, null]},
                        {"<=": [{"lookup": ["armyPosition", "gate1"]},
                                {"lookup": ["armyPosition", "gate2"]}]}]}]},
       {"and": [{"==": ["$slot", "gate2"]},
                {"or": [{"==": [{"lookup": ["armyPosition", "gate1"]}, null]},
                        {"<=": [{"lookup": ["armyPosition", "gate2"]},
                                {"lookup": ["armyPosition", "gate1"]}]}]}]}
     ]}},

    {"name": "inMeleeRange",
     "params": ["slot"],
     "body": {"and": [
       {"armyOnTrack": ["$slot"]},
       {"gateTieBreak": ["$slot"]},
       {"or": [
         {"and": [{"or": [{"==": ["$slot", "east"]}, {"==": ["$slot", "west"]},
                           {"==": ["$slot", "gate1"]}, {"==": ["$slot", "gate2"]}]},
                  {"<=": [{"lookup": ["armyPosition", "$slot"]}, 3]}]},
         {"and": [{"==": ["$slot", "sky"]},
                  {"==": [{"lookup": ["armyPosition", "$slot"]}, 1]}]},
         {"and": [{"==": ["$slot", "terror"]},
                  {"<": [{"lookup": ["armyPosition", "$slot"]}, 3]}]}
       ]}
     ]}},

    {"name": "canCastSpell",
     "params": ["spell", "caster", "energyType", "cost"],
     "body": {"and": [{"==": [{"lookup": ["spellStatusDict", "$spell"]}, ".known"]},
                       {">=": ["$energyType", "$cost"]},
                       {"heroAlive": ["$caster"]}]}},

    // ── DRM defines ──────────────────────────────────────────
    {"name": "commonAttackDRM",
     "params": ["slot"],
     "body": {"+": [
       "eventAttackDRMBonus",
       {"+": [{"if": ["inspireDRMActive", 1, 0]},
              {"if": [{"==": ["currentCard", null]}, 0,
                {"if": [{"==": ["$slot", "terror"]}, 0,
                  {"get": ["currentCard", "actionAttackDRM"]}]}]}]}
     ]}},

    {"name": "meleeDRM",
     "params": ["slot"],
     "body": {"+": [{"commonAttackDRM": ["$slot"]},
       {"+": [{"if": [{"==": ["currentCard", null]}, 0, {"get": ["currentCard", "actionMeleeDRM"]}]},
         {"+": [{"getTrackDRM": ["$slot"]},
           {"+": [{"getUpgradeMeleeDRM": ["$slot"]},
                  {"if": ["magicSwordActive", 1, 0]}]}]}]}]}},

    {"name": "rangedDRM",
     "params": ["slot"],
     "body": {"+": [{"commonAttackDRM": ["$slot"]},
       {"+": [{"if": [{"==": ["currentCard", null]}, 0, {"get": ["currentCard", "actionRangedDRM"]}]},
         {"+": [{"getTrackDRM": ["$slot"]},
           {"+": [{"getUpgradeRangedDRM": ["$slot"]},
                  {"if": ["magicBowActive", 1, 0]}]}]}]}]}},

    {"name": "heroicAttackDRM",
     "params": ["hero"],
     "body": {"+": [{"heroCombatDRM": ["$hero"]},
       {"+": [{"if": [{"==": ["currentCard", null]}, 0,
                 {"get": ["currentCard", "heroicAttackDRM"]}]},
              {"if": ["inspireDRMActive", 1, 0]}]}]}},

    {"name": "spellAttackDRM",
     "params": ["baseDRM"],
     "body": {"+": ["$baseDRM", {"if": ["inspireDRMActive", 1, 0]}]}},

    // ── Shared reducer defines ─────────────────────────────────
    {"name": "bloodyBattleCost",
     "params": ["slot"],
     "body": {"if": [{"and": [{"!=": ["bloodyBattleArmy", null]},
                               {"==": [{"slotMatchesBloodyBattle": ["$slot"]}, true]},
                               {"not": ["bloodyBattlePaidThisTurn"]}]},
       {"seq": [
         {"increment": ["defenderLossesPending", 1]},
         {"set": ["bloodyBattlePaidThisTurn", true]},
         {"log": [{"format": ["Bloody battle cost paid attacking {}", "$slot"]}]}
       ]}
     ]}},

    {"name": "resolveAttackRoll",
     "params": ["roll", "drm", "strength", "slot"],
     "body": {"if": [{"and": [{"!=": ["$roll", 1]},
                               {">": [{"+": ["$roll", "$drm"]}, "$strength"]}]},
       {"pushBackArmy": ["$slot"]},
       {"log": [{"format": ["Attack missed {}", "$slot"]}]}
     ]}},

    // ── Existing defines ───────────────────────────────────────
    // Whether time position draws from day deck (dawn/day spaces)
    {"name": "drawsFromDayDeck",
     "params": [],
     "body": {"or": [
       {"==": ["timePosition", 0]}, {"==": ["timePosition", 1]}, {"==": ["timePosition", 2]},
       {"==": ["timePosition", 6]}, {"==": ["timePosition", 7]}, {"==": ["timePosition", 8]},
       {"==": ["timePosition", 12]}, {"==": ["timePosition", 13]}, {"==": ["timePosition", 14]}
     ]}},

    // Action budget = card actions + morale modifier, min 0
    {"name": "actionBudget",
     "params": [],
     "body": {"max": [0, {"+": [
       {"get": ["currentCard", "actions"]},
       {"if": [{"==": ["morale", ".low"]}, -1,
         {"if": [{"==": ["morale", ".high"]}, 1, 0]}
       ]}
     ]}]}},

    // Remaining action points
    {"name": "actionBudgetRemaining",
     "params": [],
     "body": {"max": [0, {"-": ["snapshotActionBudget", "actionPointsSpent"]}]}},

    // Remaining heroic points
    {"name": "heroicBudgetRemaining",
     "params": [],
     "body": {"if": [{"==": ["currentCard", null]}, 0,
       {"max": [0, {"-": [{"get": ["currentCard", "heroics"]}, "heroicPointsSpent"]}]}
     ]}},

    // Men-at-Arms value at current position
    // Track values: [3, 2, 2, 2, 1, 0]
    {"name": "menAtArmsValue",
     "params": [],
     "body": {"let": ["pos", {"lookup": ["defenderPosition", "menAtArms"]},
       {"if": [{"==": ["$pos", 0]}, 3,
         {"if": [{"<=": ["$pos", 3]}, 2,
           {"if": [{"==": ["$pos", 4]}, 1, 0]}
         ]}
       ]}
     ]}},

    // Archers value at current position
    // Track values: [2, 2, 1, 1, 0]
    {"name": "archersValue",
     "params": [],
     "body": {"let": ["pos", {"lookup": ["defenderPosition", "archers"]},
       {"if": [{"<=": ["$pos", 1]}, 2,
         {"if": [{"<=": ["$pos", 3]}, 1, 0]}
       ]}
     ]}},

    // Priests value at current position
    // Track values: [2, 2, 1, 0]
    {"name": "priestsValue",
     "params": [],
     "body": {"let": ["pos", {"lookup": ["defenderPosition", "priests"]},
       {"if": [{"<=": ["$pos", 1]}, 2,
         {"if": [{"==": ["$pos", 2]}, 1, 0]}
       ]}
     ]}},

    // Track-specific attack DRM from current card (e.g. actionGateAttackDRM).
    // Returns 0 if the card doesn't have a track-specific field for this slot.
    {"name": "getTrackDRM",
     "params": ["slot"],
     "body": {"if": [{"==": ["currentCard", null]}, 0,
       {"let": ["val",
         {"if": [{"==": ["$slot", "east"]}, {"get": ["currentCard", "actionEastAttackDRM"]},
           {"if": [{"==": ["$slot", "west"]}, {"get": ["currentCard", "actionWestAttackDRM"]},
             {"if": [{"or": [{"==": ["$slot", "gate1"]}, {"==": ["$slot", "gate2"]}]},
               {"get": ["currentCard", "actionGateAttackDRM"]},
               {"if": [{"==": ["$slot", "sky"]}, {"get": ["currentCard", "actionSkyAttackDRM"]},
                 {"if": [{"==": ["$slot", "terror"]}, {"get": ["currentCard", "actionTerrorAttackDRM"]}, 0]}
               ]}
             ]}
           ]}
         ]},
         {"if": [{"==": ["$val", null]}, 0, "$val"]}
       ]}
     ]}},

    // Upgrade melee DRM: oil = +1, lava = +2 on the slot's track (only if army at space 1)
    {"name": "getUpgradeMeleeDRM",
     "params": ["slot"],
     "body": {"let": ["track",
       {"if": [{"==": ["$slot", "east"]}, "east",
         {"if": [{"==": ["$slot", "west"]}, "west",
           {"if": [{"or": [{"==": ["$slot", "gate1"]}, {"==": ["$slot", "gate2"]}]}, "gate",
             {"if": [{"==": ["$slot", "sky"]}, "sky", "terror"]}]}]}]},
       "upgrade", {"lookup": ["upgradeDict", "$track"]},
       {"if": [{"or": [{"==": ["$upgrade", null]},
                        {"!=": [{"lookup": ["armyPosition", "$slot"]}, 1]}]}, 0,
         {"if": [{"==": ["$upgrade", ".oil"]}, 1,
           {"if": [{"==": ["$upgrade", ".lava"]}, 2, 0]}
         ]}
       ]}
     ]}},

    // Upgrade ranged DRM: oil = +1 only (lava does not apply to ranged), only if army at space 1
    {"name": "getUpgradeRangedDRM",
     "params": ["slot"],
     "body": {"let": ["track",
       {"if": [{"==": ["$slot", "east"]}, "east",
         {"if": [{"==": ["$slot", "west"]}, "west",
           {"if": [{"or": [{"==": ["$slot", "gate1"]}, {"==": ["$slot", "gate2"]}]}, "gate",
             {"if": [{"==": ["$slot", "sky"]}, "sky", "terror"]}]}]}]},
       "upgrade", {"lookup": ["upgradeDict", "$track"]},
       {"if": [{"or": [{"==": ["$upgrade", null]},
                        {"!=": [{"lookup": ["armyPosition", "$slot"]}, 1]}]}, 0,
         {"if": [{"==": ["$upgrade", ".oil"]}, 1, 0]}
       ]}
     ]}},

    // Check if an army slot matches the bloody battle army
    {"name": "slotMatchesBloodyBattle",
     "params": ["slot"],
     "body": {"or": [
       {"and": [{"==": ["bloodyBattleArmy", ".east"]}, {"==": ["$slot", "east"]}]},
       {"and": [{"==": ["bloodyBattleArmy", ".west"]}, {"==": ["$slot", "west"]}]},
       {"and": [{"==": ["bloodyBattleArmy", ".gate1"]}, {"==": ["$slot", "gate1"]}]},
       {"and": [{"==": ["bloodyBattleArmy", ".gate2"]}, {"==": ["$slot", "gate2"]}]},
       {"and": [{"==": ["bloodyBattleArmy", ".sky"]}, {"==": ["$slot", "sky"]}]},
       {"and": [{"==": ["bloodyBattleArmy", ".terror"]}, {"==": ["$slot", "terror"]}]}
     ]}},

    // Does a slot's track match a hero's current location?
    // Slot "gate1"/"gate2" match hero location "gate"; others match directly.
    {"name": "slotMatchesHeroLocation",
     "params": ["slot", "hero"],
     "body": {"let": ["loc", {"lookup": ["heroLocationDict", "$hero"]},
       {"or": [
         {"and": [{"==": ["$loc", ".east"]}, {"==": ["$slot", "east"]}]},
         {"and": [{"==": ["$loc", ".west"]}, {"==": ["$slot", "west"]}]},
         {"and": [{"==": ["$loc", ".gate"]},
                  {"or": [{"==": ["$slot", "gate1"]}, {"==": ["$slot", "gate2"]}]}]},
         {"and": [{"==": ["$loc", ".sky"]}, {"==": ["$slot", "sky"]}]},
         {"and": [{"==": ["$loc", ".terror"]}, {"==": ["$slot", "terror"]}]}
       ]}
     ]}},

    // Total chant DRM
    {"name": "totalChantDRM",
     "params": [],
     "body": {"+": [
       {"priestsValue": []},
       {"if": [{"==": ["currentCard", null]}, 0, {"get": ["currentCard", "actionChantDRM"]}]},
       {"if": ["inspireDRMActive", 1, 0]}
     ]}},

    // Total rally DRM
    {"name": "totalRallyDRM",
     "params": [],
     "body": {"+": [
       {"if": [{"==": ["currentCard", null]}, 0, {"get": ["currentCard", "heroicRallyDRM"]}]},
       // Paladin +1 to rally if alive
       {"if": [{"and": [{"!=": [{"lookup": ["heroLocationDict", "paladin"]}, null]},
                         {"not": [{"contains": ["heroDead", "paladin"]}]}]},
         1, 0]},
       {"if": ["inspireDRMActive", 1, 0]}
     ]}},

    // Quest DRM: ranger +1 if alive
    {"name": "questDRM",
     "params": [],
     "body": {"if": [{"and": [{"!=": [{"lookup": ["heroLocationDict", "ranger"]}, null]},
                               {"not": [{"contains": ["heroDead", "ranger"]}]}]},
       1, 0]}},

    // All defenders at zero (defeat condition)
    {"name": "allDefendersAtZero",
     "params": [],
     "body": {"and": [
       {"==": [{"lookup": ["defenderPosition", "menAtArms"]}, 5]},
       {"and": [
         {"==": [{"lookup": ["defenderPosition", "archers"]}, 4]},
         {"==": [{"lookup": ["defenderPosition", "priests"]}, 3]}
       ]}
     ]}},

    // Lose a defender (advance position by 1, capped at last position)
    {"name": "loseDefender",
     "params": ["defType"],
     "body": {"let": ["current", {"lookup": ["defenderPosition", "$defType"]},
       "lastPos", {"if": [{"==": ["$defType", "menAtArms"]}, 5,
                    {"if": [{"==": ["$defType", "archers"]}, 4, 3]}]},
       {"if": [{"<": ["$current", "$lastPos"]},
         {"let": ["newPos", {"+": ["$current", 1]},
           {"seq": [
             {"setEntry": ["defenderPosition", "$defType", "$newPos"]},
             {"placeDefender": ["$defType", "$newPos"]}
           ]}
         ]},
         {"log": [{"format": ["{} already at zero", "$defType"]}]}
       ]}
     ]}},

    // Gain a defender (reduce position by 1, min 0)
    {"name": "gainDefender",
     "params": ["defType"],
     "body": {"let": ["current", {"lookup": ["defenderPosition", "$defType"]},
       {"if": [{">": ["$current", 0]},
         {"let": ["newPos", {"-": ["$current", 1]},
           {"seq": [
             {"setEntry": ["defenderPosition", "$defType", "$newPos"]},
             {"placeDefender": ["$defType", "$newPos"]}
           ]}
         ]},
         {"log": [{"format": ["{} already at max", "$defType"]}]}
       ]}
     ]}},

    // Lower morale one step
    {"name": "lowerMorale",
     "params": [],
     "body": {"if": [{"==": ["morale", ".high"]},
       {"set": ["morale", ".normal"]},
       {"if": [{"==": ["morale", ".normal"]},
         {"set": ["morale", ".low"]},
         {"log": ["Morale already low"]}
       ]}
     ]}},

    // Raise morale one step
    {"name": "raiseMorale",
     "params": [],
     "body": {"if": [{"==": ["morale", ".low"]},
       {"set": ["morale", ".normal"]},
       {"if": [{"==": ["morale", ".normal"]},
         {"set": ["morale", ".high"]},
         {"log": ["Morale already high"]}
       ]}
     ]}},

    // Place army piece on the board at the given track position
    {"name": "placeArmy",
     "params": ["slot", "pos"],
     "body": {"seq": [
       {"if": [{"==": ["$slot", "east"]}, {"place": ["east", {"site": ["eastTrack", "$pos"]}]}]},
       {"if": [{"==": ["$slot", "west"]}, {"place": ["west", {"site": ["westTrack", "$pos"]}]}]},
       {"if": [{"==": ["$slot", "gate1"]}, {"place": ["gate1", {"site": ["gateTrack", "$pos"]}]}]},
       {"if": [{"==": ["$slot", "gate2"]}, {"place": ["gate2", {"site": ["gateTrack", "$pos"]}]}]},
       {"if": [{"==": ["$slot", "sky"]}, {"place": ["sky", {"site": ["skyTrack", "$pos"]}]}]},
       {"if": [{"==": ["$slot", "terror"]}, {"place": ["terror", {"site": ["terrorTrack", "$pos"]}]}]}
     ]}},

    // Place defender piece on the board at the given track position
    {"name": "placeDefender",
     "params": ["defType", "pos"],
     "body": {"seq": [
       {"if": [{"==": ["$defType", "menAtArms"]}, {"place": ["menAtArms", {"site": ["menAtArmsTrack", "$pos"]}]}]},
       {"if": [{"==": ["$defType", "archers"]}, {"place": ["archers", {"site": ["archersTrack", "$pos"]}]}]},
       {"if": [{"==": ["$defType", "priests"]}, {"place": ["priests", {"site": ["priestsTrack", "$pos"]}]}]}
     ]}},

    // Push army back one space (away from castle)
    {"name": "pushBackArmy",
     "params": ["slot"],
     "body": {"let": ["pos", {"lookup": ["armyPosition", "$slot"]},
       "maxSpace", {"if": [{"==": ["$slot", "east"]}, 6,
                     {"if": [{"==": ["$slot", "west"]}, 6,
                       {"if": [{"or": [{"==": ["$slot", "gate1"]}, {"==": ["$slot", "gate2"]}]}, 4,
                         {"if": [{"==": ["$slot", "sky"]}, 6, 3]}
                       ]}
                     ]}]},
       {"if": [{"!=": ["$pos", null]},
         {"let": ["newPos", {"min": [{"+": ["$pos", 1]}, "$maxSpace"]},
           {"seq": [
             {"setEntry": ["armyPosition", "$slot", "$newPos"]},
             {"placeArmy": ["$slot", "$newPos"]}
           ]}
         ]},
         {"log": [{"format": ["{} not on board", "$slot"]}]}
       ]}
     ]}},

    // Advance a single army one space toward castle
    {"name": "advanceSingleArmy",
     "params": ["slot"],
     "body": {"let": ["pos", {"lookup": ["armyPosition", "$slot"]},
       {"if": [{"==": ["$pos", null]},
         {"log": [{"format": ["{} not on board", "$slot"]}]},
         {"seq": [
           // Check slow marker
           {"if": [{"==": ["slowedArmy", "$slot"]},
             {"seq": [
               {"set": ["slowedArmy", null]},
               {"log": [{"format": ["Slow marker removed from {}", "$slot"]}]}
             ]},
             {"seq": [
               {"let": ["newPos", {"-": ["$pos", 1]},
                 {"if": [{"<=": ["$newPos", 0]},
                   // Army reaching space 0 or below
                   {"seq": [
                     // Wall track: create breach or defeat
                     {"if": [{"or": [{"==": ["$slot", "east"]},
                                      {"==": ["$slot", "west"]},
                                      {"or": [{"==": ["$slot", "gate1"]}, {"==": ["$slot", "gate2"]}]}]},
                       {"handleBreach": ["$slot"]},
                       // Rule 4.4: Terror/Sky reaching castle — lose a defender, army stays at 1
                       {"seq": [
                         {"increment": ["defenderLossesPending", 1]},
                         {"setEntry": ["armyPosition", "$slot", 1]},
                         {"placeArmy": ["$slot", 1]},
                         {"log": [{"format": ["{} army reached castle — stays at 1, choose defender to lose", "$slot"]}]}
                       ]}
                     ]}
                   ]},
                   // Normal advance
                   {"seq": [
                     {"setEntry": ["armyPosition", "$slot", "$newPos"]},
                     {"placeArmy": ["$slot", "$newPos"]}
                   ]}
                 ]}
               ]}
             ]}
           ]}
         ]}
       ]}
     ]}},

    // Handle breach when army reaches space 0 on a wall track
    {"name": "handleBreach",
     "params": ["slot"],
     "body": {"let": ["track", {"if": [{"==": ["$slot", "east"]}, ".east",
                                  {"if": [{"==": ["$slot", "west"]}, ".west", ".gate"]}]},
       "trackKey", {"if": [{"==": ["$slot", "east"]}, "east",
                     {"if": [{"==": ["$slot", "west"]}, "west", "gate"]}]},
       // Grease: Rule 6.3.2 — roll d6, 1-2 prevents breach, 3-6 breach happens. Grease consumed only on failure.
       {"if": [{"==": [{"lookup": ["upgradeDict", "$trackKey"]}, ".grease"]},
         {"let": ["greaseRoll", {"rollDie": [6]},
           {"seq": [
             {"if": [{"<=": ["$greaseRoll", 2]},
               {"seq": [
                 {"setEntry": ["armyPosition", "$slot", 1]},
                 {"placeArmy": ["$slot", 1]},
                 {"log": [{"format": ["Grease held on {}! (roll {} <= 2) Army stays at 1", "$track", "$greaseRoll"]}]}
               ]},
               {"seq": [
                 {"removeEntry": ["upgradeDict", "$trackKey"]},
                 {"log": [{"format": ["Grease failed on {} (roll {} > 2), breach proceeds", "$track", "$greaseRoll"]}]},
                 // Fall through to normal breach logic
                 {"if": [{"contains": ["barricades", "$track"]},
                   // Barricade test after grease failure: Rule 4.1.3 — roll <= strength = barricade holds (breach), > = defeat
                   {"let": ["broll", {"rollDie": [6]},
                     "bstr", {"lookup": ["armyStrengthDict", "$slot"]},
                     {"if": [{"<=": ["$broll", "$bstr"]},
                       // Barricade absorbs blow — becomes breach
                       {"seq": [
                         {"removeFrom": ["barricades", "$track"]},
                         {"insertInto": ["breaches", "$track"]},
                         {"removeEntry": ["upgradeDict", "$trackKey"]},
                         {"setEntry": ["armyPosition", "$slot", 1]},
                         {"placeArmy": ["$slot", 1]},
                         {"log": [{"format": ["Barricade held on {} → breach (grease failed, roll {} <= str {})", "$track", "$broll", "$bstr"]}]}
                       ]},
                       // Army overpowers barricade — defeat
                       {"seq": [
                         {"removeFrom": ["barricades", "$track"]},
                         {"setEntry": ["armyPosition", "$slot", 0]},
                         {"placeArmy": ["$slot", 0]},
                         {"set": ["ended", true]},
                         {"log": [{"format": ["Army broke through barricade on {} — defeat! (grease failed, roll {} > str {})", "$track", "$broll", "$bstr"]}]}
                       ]}
                     ]}
                   ]},
                   {"if": [{"not": [{"contains": ["breaches", "$track"]}]},
                     {"seq": [
                       {"insertInto": ["breaches", "$track"]},
                       {"removeEntry": ["upgradeDict", "$trackKey"]},
                       {"log": [{"format": ["Breach created on {} (grease failed)", "$track"]}]}
                     ]},
                     {"seq": [
                       {"setEntry": ["armyPosition", "$slot", 0]},
                       {"placeArmy": ["$slot", 0]},
                       {"set": ["ended", true]},
                       {"log": [{"format": ["Army entered castle via {} — defeat!", "$track"]}]}
                     ]}
                   ]}
                 ]}
               ]}
             ]}
           ]}
         ]},
         {"if": [{"contains": ["barricades", "$track"]},
           // Barricade test: Rule 4.1.3 — roll <= strength = barricade holds (becomes breach)
           // roll > strength = army breaks through = defeat
           {"let": ["roll", {"rollDie": [6]},
             "strength", {"lookup": ["armyStrengthDict", "$slot"]},
             {"if": [{"<=": ["$roll", "$strength"]},
               // Barricade absorbs the blow — becomes breach, army stays at 1
               {"seq": [
                 {"removeFrom": ["barricades", "$track"]},
                 {"insertInto": ["breaches", "$track"]},
                 {"removeEntry": ["upgradeDict", "$trackKey"]},
                 {"setEntry": ["armyPosition", "$slot", 1]},
                 {"placeArmy": ["$slot", 1]},
                 {"log": [{"format": ["Barricade held on {} → breach (roll {} <= str {})", "$track", "$roll", "$strength"]}]}
               ]},
               // Army overpowers barricade — defeat
               {"seq": [
                 {"removeFrom": ["barricades", "$track"]},
                 {"setEntry": ["armyPosition", "$slot", 0]},
                 {"placeArmy": ["$slot", 0]},
                 {"set": ["ended", true]},
                 {"log": [{"format": ["Army broke through barricade on {} — defeat! (roll {} > str {})", "$track", "$roll", "$strength"]}]}
               ]}
             ]}
           ]},
           {"if": [{"not": [{"contains": ["breaches", "$track"]}]},
             // First time: create breach, remove any upgrade
             {"seq": [
               {"insertInto": ["breaches", "$track"]},
               {"removeEntry": ["upgradeDict", "$trackKey"]},
               {"log": [{"format": ["Breach created on {}", "$track"]}]}
             ]},
             // Breach already exists: army enters castle — defeat
             {"seq": [
               {"setEntry": ["armyPosition", "$slot", 0]},
               {"placeArmy": ["$slot", 0]},
               {"set": ["ended", true]},
               {"log": [{"format": ["Army entered castle via {} — defeat!", "$track"]}]}
             ]}
           ]}
         ]}
       ]}
     ]}},

    // Advance armies from current card's advance array
    {"name": "advanceArmiesFromCard",
     "params": [],
     "body": {"if": [{"!=": ["currentCard", null]},
       {"forEach": [{"get": ["currentCard", "advances"]},
         {"fn": ["trackName",
           {"if": [{"==": ["$trackName", "gate"]},
             {"advanceGateArmies": []},
             {"let": ["slot", {"if": [{"==": ["$trackName", "east"]}, "east",
                                {"if": [{"==": ["$trackName", "west"]}, "west",
                                  {"if": [{"==": ["$trackName", "sky"]}, "sky", "terror"]}]}]},
               {"advanceSingleArmy": ["$slot"]}
             ]}
           ]}
         ]}
       ]},
       {"log": ["No card to advance"]}
     ]}},

    // Rule 4.1.1: Gate track advancement: FARTHEST army advances; if tied, both advance
    {"name": "advanceGateArmies",
     "params": [],
     "body": {"let": ["pos1", {"lookup": ["armyPosition", "gate1"]},
                       "pos2", {"lookup": ["armyPosition", "gate2"]},
       {"if": [{"and": [{"==": ["$pos1", null]}, {"==": ["$pos2", null]}]},
         {"log": ["No gate armies"]},
         {"if": [{"==": ["$pos1", null]},
           {"advanceSingleArmy": ["gate2"]},
           {"if": [{"==": ["$pos2", null]},
             {"advanceSingleArmy": ["gate1"]},
             // Higher position = farther from castle — farthest advances first
             {"if": [{">": ["$pos1", "$pos2"]},
               {"advanceSingleArmy": ["gate1"]},
               {"if": [{">": ["$pos2", "$pos1"]},
                 {"advanceSingleArmy": ["gate2"]},
                 // Tied: advance together per Rule 4.1.1
                 // Save gate1 position, advance gate1, then mirror result to gate2
                 {"let": ["gate1PosBefore", "$pos1",
                   {"seq": [
                     {"advanceSingleArmy": ["gate1"]},
                     {"let": ["gate1PosAfter", {"lookup": ["armyPosition", "gate1"]},
                       {"if": ["ended",
                         // gate1 entered castle (existing breach) — gate2 enters too
                         {"seq": [
                           {"setEntry": ["armyPosition", "gate2", 0]},
                           {"placeArmy": ["gate2", 0]},
                           {"log": ["gate2 also entered castle — defeat!"]}
                         ]},
                         {"if": [{"==": ["$gate1PosAfter", "$gate1PosBefore"]},
                           // gate1 didn't move (grease held, barricade held, slow removed) — gate2 stays too
                           {"seq": [
                             {"setEntry": ["armyPosition", "gate2", "$gate1PosAfter"]},
                             {"placeArmy": ["gate2", "$gate1PosAfter"]},
                             {"log": ["Both gate armies stayed (grease/barricade held or slow removed)"]}
                           ]},
                           {"if": [{"contains": ["breaches", ".gate"]},
                             // Breach was just created — gate2 stays at 1 with gate1
                             {"seq": [
                               {"setEntry": ["armyPosition", "gate2", 1]},
                               {"placeArmy": ["gate2", 1]},
                               {"log": ["Both gate armies at 1 after breach"]}
                             ]},
                             // Normal advance — set gate2 to same position as gate1
                             {"seq": [
                               {"setEntry": ["armyPosition", "gate2", "$gate1PosAfter"]},
                               {"placeArmy": ["gate2", "$gate1PosAfter"]},
                               {"log": [{"format": ["Both gate armies advanced to {}", "$gate1PosAfter"]}]}
                             ]}
                           ]}
                         ]}
                       ]}
                     ]}
                   ]}
                 ]}
               ]}
             ]}
           ]}
         ]}
       ]}
     ]}},

    // Advance time by one step with twilight/dawn effects
    {"name": "advanceTimeOneStep",
     "params": [],
     "body": {"seq": [
       {"increment": ["timePosition", 1]},
       {"if": [{"or": [{"==": ["timePosition", 3]},
                        {"or": [{"==": ["timePosition", 9]},
                                 {"==": ["timePosition", 15]}]}]},
         {"seq": [
           {"set": ["arcaneEnergy", {"min": [6, {"+": ["arcaneEnergy", 1]}]}]},
           {"setEntry": ["armyPosition", "terror", 3]},
           {"place": ["terror", {"site": ["terrorTrack", 3]}]},
           {"log": ["Twilight: +1 arcane, terror placed at 3"]}
         ]},
         {"if": [{"or": [{"==": ["timePosition", 6]}, {"==": ["timePosition", 12]}]},
           // Rule 3.1.2: Dawn = -1 morale, +1 arcane, remove terror
           {"seq": [
             {"lowerMorale": []},
             {"set": ["arcaneEnergy", {"min": [6, {"+": ["arcaneEnergy", 1]}]}]},
             {"removeEntry": ["armyPosition", "terror"]},
             {"remove": ["terror"]},
             {"log": ["Dawn: -1 morale, +1 arcane, terror removed"]}
           ]},
           {"log": [{"format": ["Time advanced to {}", "timePosition"]}]}
         ]}
       ]}
     ]}},

    // Advance time marker by N spaces (unrolled, max 3)
    {"name": "advanceTime",
     "params": ["spaces"],
     "body": {"seq": [
       {"if": [{">=": ["$spaces", 1]}, {"advanceTimeOneStep": []}]},
       {"if": [{">=": ["$spaces", 2]}, {"advanceTimeOneStep": []}]},
       {"if": [{">=": ["$spaces", 3]}, {"advanceTimeOneStep": []}]}
     ]}},

    // Advance farthest army one space
    {"name": "advanceFarthestArmyOnce",
     "params": [],
     "body": {"let": ["farthestSlot", {"findFarthestArmy": []},
       {"if": [{"!=": ["$farthestSlot", null]},
         {"advanceSingleArmy": ["$farthestSlot"]},
         {"log": ["No armies to advance"]}
       ]}
     ]}},

    // Advance farthest army N spaces (unrolled, max 6)
    {"name": "advanceFarthestArmy",
     "params": ["count"],
     "body": {"seq": [
       {"if": [{">=": ["$count", 1]}, {"advanceFarthestArmyOnce": []}]},
       {"if": [{">=": ["$count", 2]}, {"advanceFarthestArmyOnce": []}]},
       {"if": [{">=": ["$count", 3]}, {"advanceFarthestArmyOnce": []}]},
       {"if": [{">=": ["$count", 4]}, {"advanceFarthestArmyOnce": []}]},
       {"if": [{">=": ["$count", 5]}, {"advanceFarthestArmyOnce": []}]},
       {"if": [{">=": ["$count", 6]}, {"advanceFarthestArmyOnce": []}]}
     ]}},

    // Find farthest army slot
    {"name": "findFarthestArmy",
     "params": [],
     "body": {"let": [
       "eastPos", {"if": [{"!=": [{"lookup": ["armyPosition", "east"]}, null]},
                     {"lookup": ["armyPosition", "east"]}, 0]},
       "westPos", {"if": [{"!=": [{"lookup": ["armyPosition", "west"]}, null]},
                     {"lookup": ["armyPosition", "west"]}, 0]},
       "g1Pos", {"if": [{"!=": [{"lookup": ["armyPosition", "gate1"]}, null]},
                   {"lookup": ["armyPosition", "gate1"]}, 0]},
       "g2Pos", {"if": [{"!=": [{"lookup": ["armyPosition", "gate2"]}, null]},
                   {"lookup": ["armyPosition", "gate2"]}, 0]},
       "skyPos", {"if": [{"!=": [{"lookup": ["armyPosition", "sky"]}, null]},
                    {"lookup": ["armyPosition", "sky"]}, 0]},
       "terrorPos", {"if": [{"!=": [{"lookup": ["armyPosition", "terror"]}, null]},
                      {"lookup": ["armyPosition", "terror"]}, 0]},
       "maxPos", {"max": ["$eastPos", {"max": ["$westPos", {"max": ["$g1Pos",
                   {"max": ["$g2Pos", {"max": ["$skyPos", "$terrorPos"]}]}]}]}]},
       {"if": [{"==": ["$maxPos", 0]}, null,
         {"if": [{"==": ["$eastPos", "$maxPos"]}, "east",
           {"if": [{"==": ["$westPos", "$maxPos"]}, "west",
             {"if": [{"==": ["$g1Pos", "$maxPos"]}, "gate1",
               {"if": [{"==": ["$g2Pos", "$maxPos"]}, "gate2",
                 {"if": [{"==": ["$skyPos", "$maxPos"]}, "sky", "terror"]}
               ]}
             ]}
           ]}
         ]}
       ]}
     ]}},

    // Max position among all armies (0 if none on board)
    {"name": "farthestArmyMaxPos",
     "params": [],
     "body": {"let": [
       "eastPos", {"if": [{"!=": [{"lookup": ["armyPosition", "east"]}, null]},
                     {"lookup": ["armyPosition", "east"]}, 0]},
       "westPos", {"if": [{"!=": [{"lookup": ["armyPosition", "west"]}, null]},
                     {"lookup": ["armyPosition", "west"]}, 0]},
       "g1Pos", {"if": [{"!=": [{"lookup": ["armyPosition", "gate1"]}, null]},
                   {"lookup": ["armyPosition", "gate1"]}, 0]},
       "g2Pos", {"if": [{"!=": [{"lookup": ["armyPosition", "gate2"]}, null]},
                   {"lookup": ["armyPosition", "gate2"]}, 0]},
       "skyPos", {"if": [{"!=": [{"lookup": ["armyPosition", "sky"]}, null]},
                    {"lookup": ["armyPosition", "sky"]}, 0]},
       "terrorPos", {"if": [{"!=": [{"lookup": ["armyPosition", "terror"]}, null]},
                      {"lookup": ["armyPosition", "terror"]}, 0]},
       {"max": ["$eastPos", {"max": ["$westPos", {"max": ["$g1Pos",
                 {"max": ["$g2Pos", {"max": ["$skyPos", "$terrorPos"]}]}]}]}]}
     ]}},

    // Count how many armies are tied at the farthest position
    {"name": "farthestArmyTieCount",
     "params": [],
     "body": {"let": [
       "maxPos", {"farthestArmyMaxPos": []},
       "eastTied", {"if": [{"and": [{">": ["$maxPos", 0]},
                     {"==": [{"lookup": ["armyPosition", "east"]}, "$maxPos"]}]}, 1, 0]},
       "westTied", {"if": [{"and": [{">": ["$maxPos", 0]},
                     {"==": [{"lookup": ["armyPosition", "west"]}, "$maxPos"]}]}, 1, 0]},
       "g1Tied", {"if": [{"and": [{">": ["$maxPos", 0]},
                   {"==": [{"lookup": ["armyPosition", "gate1"]}, "$maxPos"]}]}, 1, 0]},
       "g2Tied", {"if": [{"and": [{">": ["$maxPos", 0]},
                   {"==": [{"lookup": ["armyPosition", "gate2"]}, "$maxPos"]}]}, 1, 0]},
       "skyTied", {"if": [{"and": [{">": ["$maxPos", 0]},
                    {"==": [{"lookup": ["armyPosition", "sky"]}, "$maxPos"]}]}, 1, 0]},
       "terrorTied", {"if": [{"and": [{">": ["$maxPos", 0]},
                       {"==": [{"lookup": ["armyPosition", "terror"]}, "$maxPos"]}]}, 1, 0]},
       {"+": ["$eastTied", {"+": ["$westTied", {"+": ["$g1Tied",
               {"+": ["$g2Tied", {"+": ["$skyTied", "$terrorTied"]}]}]}]}]}
     ]}},

    // Is this slot tied at the farthest position? (for harbingers param filtering)
    {"name": "isSlotAtFarthestPos",
     "params": ["slot"],
     "body": {"let": [
       "maxPos", {"farthestArmyMaxPos": []},
       "slotPos", {"lookup": ["armyPosition", "$slot"]},
       {"and": [{">": ["$maxPos", 0]},
               {"!=": ["$slotPos", null]},
               {"==": ["$slotPos", "$maxPos"]}]}
     ]}},

    // Resolve melee attack on a given slot
    // resolveMeleeAttack and resolveRangedAttack deleted — dead code.
    // initiateMeleeAttack/initiateRangedAttack always go through stored-roll path.

    // Resolve build upgrade
    {"name": "resolveBuildUpgrade",
     "params": ["upgrade", "track"],
     "body": {"let": ["roll", {"rollDie": [6]},
       "buildNum", {"upgradeBuildNumber": ["$upgrade"]},
       "cardDRM", {"if": [{"==": ["currentCard", null]}, 0, {"get": ["currentCard", "actionBuildDRM"]}]},
       "rogueDRM", {"if": [{"and": [{"!=": [{"lookup": ["heroLocationDict", "rogue"]}, null]},
                                      {"not": [{"contains": ["heroDead", "rogue"]}]}]}, 1, 0]},
       "drm", {"+": ["$cardDRM", {"+": ["$rogueDRM", {"if": ["inspireDRMActive", 1, 0]}]}]},
       {"seq": [
         {"if": [{"and": [{"!=": ["$roll", 1]},
                            {">": [{"+": ["$roll", "$drm"]}, "$buildNum"]}]},
           {"seq": [
             {"setEntry": ["upgradeDict", "$track", "$upgrade"]},
             {"log": [{"format": ["Built {} on {}", "$upgrade", "$track"]}]}
           ]},
           {"log": [{"format": ["Build {} on {} failed: rolled {} + {} vs {}",
             "$upgrade", "$track", "$roll", "$drm", "$buildNum"]}]}
         ]},
         {"increment": ["actionPointsSpent", 1]}
       ]}
     ]}},

    // Resolve barricade build
    {"name": "resolveBarricade",
     "params": ["track"],
     "body": {"let": ["roll", {"rollDie": [6]},
       "cardDRM", {"if": [{"==": ["currentCard", null]}, 0, {"get": ["currentCard", "actionBuildDRM"]}]},
       "rogueDRM", {"if": [{"and": [{"!=": [{"lookup": ["heroLocationDict", "rogue"]}, null]},
                                      {"not": [{"contains": ["heroDead", "rogue"]}]}]}, 1, 0]},
       "drm", {"+": ["$cardDRM", {"+": ["$rogueDRM", {"if": ["inspireDRMActive", 1, 0]}]}]},
       {"seq": [
         {"if": [{"and": [{"!=": ["$roll", 1]},
                            {">": [{"+": ["$roll", "$drm"]}, 2]}]},
           {"seq": [
             {"removeFrom": ["breaches", "$track"]},
             {"insertInto": ["barricades", "$track"]},
             {"log": [{"format": ["Barricade built on {}", "$track"]}]}
           ]},
           {"log": [{"format": ["Barricade on {} failed: rolled {} + {}",
             "$track", "$roll", "$drm"]}]}
         ]},
         {"increment": ["actionPointsSpent", 1]}
       ]}
     ]}},

    // Wound a hero (already wounded => killed)
    {"name": "woundHero",
     "params": ["hero"],
     "body": {"if": [{"contains": ["heroWounded", "$hero"]},
       {"killHero": ["$hero"]},
       {"insertInto": ["heroWounded", "$hero"]}
     ]}},

    // Kill a hero
    {"name": "killHero",
     "params": ["hero"],
     "body": {"seq": [
       {"insertInto": ["heroDead", "$hero"]},
       {"removeFrom": ["heroWounded", "$hero"]},
       {"removeEntry": ["heroLocationDict", "$hero"]},
       {"log": [{"format": ["{} killed!", "$hero"]}]}
     ]}},

    // Wound all unwounded heroes (Acts of Valor) — DRM handled at call site
    {"name": "woundAllUnwoundedHeroes",
     "params": [],
     "body": {"forEach": [{"list": ["warrior", "wizard", "ranger", "rogue", "paladin", "cleric"]},
       {"fn": ["h",
         {"if": [{"and": [{"!=": [{"lookup": ["heroLocationDict", "$h"]}, null]},
                            {"not": [{"contains": ["heroDead", "$h"]}]},
                            {"not": [{"contains": ["heroWounded", "$h"]}]}]},
           {"seq": [
             {"insertInto": ["heroWounded", "$h"]},
             {"log": [{"format": ["Wounded {}", "$h"]}]}
           ]},
           {"log": [{"format": ["{} already wounded, dead, or absent", "$h"]}]}
         ]}
       ]}
     ]}},

    // Check if any hero is alive and unwounded
    {"name": "anyHeroUnwounded",
     "params": [],
     "body": {"or": [
       {"and": [{"!=": [{"lookup": ["heroLocationDict", "warrior"]}, null]},
                {"not": [{"contains": ["heroDead", "warrior"]}]},
                {"not": [{"contains": ["heroWounded", "warrior"]}]}]},
       {"and": [{"!=": [{"lookup": ["heroLocationDict", "wizard"]}, null]},
                {"not": [{"contains": ["heroDead", "wizard"]}]},
                {"not": [{"contains": ["heroWounded", "wizard"]}]}]},
       {"and": [{"!=": [{"lookup": ["heroLocationDict", "ranger"]}, null]},
                {"not": [{"contains": ["heroDead", "ranger"]}]},
                {"not": [{"contains": ["heroWounded", "ranger"]}]}]},
       {"and": [{"!=": [{"lookup": ["heroLocationDict", "rogue"]}, null]},
                {"not": [{"contains": ["heroDead", "rogue"]}]},
                {"not": [{"contains": ["heroWounded", "rogue"]}]}]},
       {"and": [{"!=": [{"lookup": ["heroLocationDict", "paladin"]}, null]},
                {"not": [{"contains": ["heroDead", "paladin"]}]},
                {"not": [{"contains": ["heroWounded", "paladin"]}]}]},
       {"and": [{"!=": [{"lookup": ["heroLocationDict", "cleric"]}, null]},
                {"not": [{"contains": ["heroDead", "cleric"]}]},
                {"not": [{"contains": ["heroWounded", "cleric"]}]}]}
     ]}},

    // Rule 6.3.2: acid eligible = track has acid upgrade AND army at space 1
    {"name": "anyAcidEligible",
     "params": [],
     "body": {"or": [
       {"and": [{"==": [{"lookup": ["upgradeDict", "east"]}, ".acid"]},
                {"==": [{"lookup": ["armyPosition", "east"]}, 1]}]},
       {"and": [{"==": [{"lookup": ["upgradeDict", "west"]}, ".acid"]},
                {"==": [{"lookup": ["armyPosition", "west"]}, 1]}]},
       {"and": [{"==": [{"lookup": ["upgradeDict", "gate1"]}, ".acid"]},
                {"==": [{"lookup": ["armyPosition", "gate1"]}, 1]}]},
       {"and": [{"==": [{"lookup": ["upgradeDict", "gate2"]}, ".acid"]},
                {"==": [{"lookup": ["armyPosition", "gate2"]}, 1]}]}
     ]}},

    // Check if any living hero is wounded (for wounded-first targeting)
    {"name": "anyLivingWoundedHero",
     "params": [],
     "body": {"or": [
       {"and": [{"not": [{"contains": ["heroDead", "warrior"]}]},
                {"contains": ["heroWounded", "warrior"]}]},
       {"and": [{"not": [{"contains": ["heroDead", "wizard"]}]},
                {"contains": ["heroWounded", "wizard"]}]},
       {"and": [{"not": [{"contains": ["heroDead", "ranger"]}]},
                {"contains": ["heroWounded", "ranger"]}]},
       {"and": [{"not": [{"contains": ["heroDead", "rogue"]}]},
                {"contains": ["heroWounded", "rogue"]}]},
       {"and": [{"not": [{"contains": ["heroDead", "paladin"]}]},
                {"contains": ["heroWounded", "paladin"]}]},
       {"and": [{"not": [{"contains": ["heroDead", "cleric"]}]},
                {"contains": ["heroWounded", "cleric"]}]}
     ]}},

    // Return all living heroes to reserves (Council of Heroes)
    {"name": "returnAllHeroesToReserves",
     "params": [],
     "body": {"forEach": [{"list": ["warrior", "wizard", "ranger", "rogue", "paladin", "cleric"]},
       {"fn": ["h",
         {"if": [{"and": [{"!=": [{"lookup": ["heroLocationDict", "$h"]}, null]},
                            {"not": [{"contains": ["heroDead", "$h"]}]}]},
           {"setEntry": ["heroLocationDict", "$h", ".reserves"]},
           {"log": [{"format": ["{} not in play", "$h"]}]}
         ]}
       ]}
     ]}},

    // Return all cast spells to face-down (Mystic Forces Reborn)
    {"name": "returnCastSpellsToFaceDown",
     "params": [],
     "body": {"forEach": [
       {"list": ["fireball", "slow", "chainLightning", "fortune",
                 "cureWounds", "massHeal", "divineWrath", "inspire", "raiseDead"]},
       {"fn": ["s",
         {"if": [{"==": [{"lookup": ["spellStatusDict", "$s"]}, ".cast"]},
           {"setEntry": ["spellStatusDict", "$s", ".faceDown"]},
           {"log": [{"format": ["{} not cast", "$s"]}]}
         ]}
       ]}
     ]}},

    // Memorize random arcane spell
    {"name": "memorizeRandomArcane",
     "params": [],
     "body": {"let": ["available", {"filter": [
         {"list": ["fireball", "slow", "chainLightning", "fortune"]},
         {"fn": ["s", {"==": [{"lookup": ["spellStatusDict", "$s"]}, ".faceDown"]}]}
       ]},
       {"if": [{"isEmpty": ["$available"]},
         {"log": ["No face-down arcane spells"]},
         {"let": ["spell", {"randomElement": ["$available"]},
           {"seq": [
             {"setEntry": ["spellStatusDict", "$spell", ".known"]},
             {"log": [{"format": ["Memorized {}", "$spell"]}]}
           ]}
         ]}
       ]}
     ]}},

    // Pray random divine spell
    {"name": "prayRandomDivine",
     "params": [],
     "body": {"let": ["available", {"filter": [
         {"list": ["cureWounds", "massHeal", "divineWrath", "inspire", "raiseDead"]},
         {"fn": ["s", {"==": [{"lookup": ["spellStatusDict", "$s"]}, ".faceDown"]}]}
       ]},
       {"if": [{"isEmpty": ["$available"]},
         {"log": ["No face-down divine spells"]},
         {"let": ["spell", {"randomElement": ["$available"]},
           {"seq": [
             {"setEntry": ["spellStatusDict", "$spell", ".known"]},
             {"log": [{"format": ["Prayed for {}", "$spell"]}]}
           ]}
         ]}
       ]}
     ]}},

    // Advance closest of East/West (Broken Walls event)
    {"name": "advanceClosestEastWest",
     "params": [],
     "body": {"let": [
       "eastPos", {"lookup": ["armyPosition", "east"]},
       "westPos", {"lookup": ["armyPosition", "west"]},
       {"if": [{"and": [{"==": ["$eastPos", null]}, {"==": ["$westPos", null]}]},
         {"log": ["No East/West armies"]},
         {"if": [{"==": ["$eastPos", null]},
           {"advanceSingleArmy": ["west"]},
           {"if": [{"==": ["$westPos", null]},
             {"advanceSingleArmy": ["east"]},
             {"if": [{"<": ["$eastPos", "$westPos"]},
               {"advanceSingleArmy": ["east"]},
               {"if": [{"<": ["$westPos", "$eastPos"]},
                 {"advanceSingleArmy": ["west"]},
                 // Tied: advance both
                 {"seq": [
                   {"advanceSingleArmy": ["east"]},
                   {"advanceSingleArmy": ["west"]}
                 ]}
               ]}
             ]}
           ]}
         ]}
       ]}
     ]}},

    // Resolve quest reward based on card number
    {"name": "resolveQuestReward",
     "params": [],
     "body": {"let": ["cardNum", {"get": ["currentCard", "questNumber"]},
       {"if": [{"==": ["$cardNum", 3]},
         // Forlorn Hope: time +1
         {"advanceTime": [1]},
         {"if": [{"==": ["$cardNum", 5]},
           // Manastones: +1 arcane, +1 divine
           {"seq": [
             {"set": ["arcaneEnergy", {"min": [6, {"+": ["arcaneEnergy", 1]}]}]},
             {"set": ["divineEnergy", {"min": [6, {"+": ["divineEnergy", 1]}]}]}
           ]},
           {"if": [{"==": ["$cardNum", 13]},
             // Amdir (same as Forlorn Hope): time +1
             {"advanceTime": [1]},
             {"if": [{"==": ["$cardNum", 6]},
               // Magic Bow: +1 ranged DRM, consumed after use
               {"seq": [
                 {"set": ["magicBowActive", true]},
                 {"set": ["questRewardPending", false]}
               ]},
               {"if": [{"==": ["$cardNum", 19]},
                 // Magic Sword: +1 melee DRM, consumed after use
                 {"seq": [
                   {"set": ["magicSwordActive", true]},
                   {"set": ["questRewardPending", false]}
                 ]},
                 {"if": [{"==": ["$cardNum", 25]},
                   // Mirror of Moon: +2 arcane
                   {"set": ["arcaneEnergy", {"min": [6, {"+": ["arcaneEnergy", 2]}]}]},
                   // Cards 2, 10, 15, 22, 28: need player choice
                   {"set": ["questRewardPending", true]}
                 ]}
               ]}
             ]}
           ]}
         ]}
       ]}
     ]}},

    // Rule 10.5: Paladin can re-roll any one die per turn (alive, not wounded, not used)
    {"name": "paladinCanReroll",
     "params": [],
     "body": {"and": [
       {"!=": [{"lookup": ["heroLocationDict", "paladin"]}, null]},
       {"not": [{"contains": ["heroDead", ".paladin"]}]},
       {"not": [{"contains": ["heroWounded", ".paladin"]}]},
       {"not": ["paladinRerollUsed"]}
     ]}},

    // Initiate a melee attack with paladin reroll check
    {"name": "initiateMeleeAttack",
     "params": ["slot"],
     "body": {"seq": [
       {"set": ["lastDieRoll", {"rollDie": [6]}]},
       {"set": ["pendingSlot", "$slot"]},
       {"set": ["pendingRoll", ".melee"]},
       {"if": [{"paladinCanReroll": []},
         {"seq": [
           {"setPhase": [".paladinReact"]},
           {"log": [{"format": ["Paladin may reroll melee {} (rolled {})", "$slot", "lastDieRoll"]}]}
         ]},
         {"seq": [
           {"resolveMelee": ["$slot"]},
           {"set": ["pendingRoll", ".none"]},
           {"set": ["pendingSlot", null]}
         ]}
       ]}
     ]}},

    // Resolve melee using lastDieRoll from state
    {"name": "resolveMelee",
     "params": ["slot"],
     "body": {"let": ["roll", "lastDieRoll",
       "strength", {"lookup": ["armyStrengthDict", "$slot"]},
       "drm", {"meleeDRM": ["$slot"]},
       {"seq": [
         {"if": ["magicSwordActive", {"set": ["magicSwordActive", false]}]},
         {"bloodyBattleCost": ["$slot"]},
         {"resolveAttackRoll": ["$roll", "$drm", "$strength", "$slot"]},
         {"increment": ["actionPointsSpent", 1]},
         {"increment": ["meleeAttacksThisTurn", 1]},
         {"log": [{"format": ["Melee on {}: rolled {} + {} vs {}",
           "$slot", "$roll", "$drm", "$strength"]}]}
       ]}
     ]}},

    // Initiate a ranged attack with paladin reroll check
    {"name": "initiateRangedAttack",
     "params": ["slot"],
     "body": {"seq": [
       {"set": ["lastDieRoll", {"rollDie": [6]}]},
       {"set": ["pendingSlot", "$slot"]},
       {"set": ["pendingRoll", ".ranged"]},
       {"if": [{"paladinCanReroll": []},
         {"seq": [
           {"setPhase": [".paladinReact"]},
           {"log": [{"format": ["Paladin may reroll ranged {} (rolled {})", "$slot", "lastDieRoll"]}]}
         ]},
         {"seq": [
           {"resolveRanged": ["$slot"]},
           {"set": ["pendingRoll", ".none"]},
           {"set": ["pendingSlot", null]}
         ]}
       ]}
     ]}},

    // Resolve ranged using lastDieRoll from state
    {"name": "resolveRanged",
     "params": ["slot"],
     "body": {"let": ["roll", "lastDieRoll",
       "strength", {"lookup": ["armyStrengthDict", "$slot"]},
       "drm", {"rangedDRM": ["$slot"]},
       {"seq": [
         {"if": ["magicBowActive", {"set": ["magicBowActive", false]}]},
         {"bloodyBattleCost": ["$slot"]},
         {"resolveAttackRoll": ["$roll", "$drm", "$strength", "$slot"]},
         {"increment": ["actionPointsSpent", 1]},
         {"increment": ["rangedAttacksThisTurn", 1]},
         {"log": [{"format": ["Ranged on {}: rolled {} + {} vs {}",
           "$slot", "$roll", "$drm", "$strength"]}]}
       ]}
     ]}},

    // Initiate heroic attack with paladin reroll check
    {"name": "initiateHeroicAttack",
     "params": ["hero", "slot"],
     "body": {"seq": [
       {"set": ["lastDieRoll", {"rollDie": [6]}]},
       {"set": ["pendingSlot", "$slot"]},
       {"set": ["pendingHero", "$hero"]},
       {"set": ["pendingRoll", ".heroicAttack"]},
       {"if": [{"paladinCanReroll": []},
         {"seq": [
           {"setPhase": [".paladinReact"]},
           {"log": [{"format": ["Paladin may reroll heroic {} vs {} (rolled {})",
             "$hero", "$slot", "lastDieRoll"]}]}
         ]},
         {"seq": [
           {"resolveHeroicWithStoredRoll": ["$hero", "$slot"]},
           {"set": ["pendingRoll", ".none"]},
           {"set": ["pendingSlot", null]},
           {"set": ["pendingHero", null]}
         ]}
       ]}
     ]}},

    // Resolve heroic attack using lastDieRoll from state
    {"name": "resolveHeroicWithStoredRoll",
     "params": ["hero", "slot"],
     "body": {"let": ["roll", "lastDieRoll",
       "strength", {"lookup": ["armyStrengthDict", "$slot"]},
       "drm", {"heroicAttackDRM": ["$hero"]},
       {"seq": [
         {"resolveAttackRoll": ["$roll", "$drm", "$strength", "$slot"]},
         {"if": [{"and": [{"==": ["$roll", 1]},
                            {"!=": ["$hero", "warrior"]},
                            {"!=": ["$hero", "ranger"]}]},
           {"woundHero": ["$hero"]},
           {"log": ["No wounding"]}
         ]},
         {"increment": ["heroicPointsSpent", 1]},
         {"log": [{"format": ["Heroic attack: {} vs {} rolled {} + {}",
           "$hero", "$slot", "$roll", "$drm"]}]}
       ]}
     ]}},

    // Initiate rally with paladin reroll check
    {"name": "initiateRally",
     "params": [],
     "body": {"seq": [
       {"set": ["lastDieRoll", {"rollDie": [6]}]},
       {"set": ["pendingRoll", ".rally"]},
       {"if": [{"paladinCanReroll": []},
         {"seq": [
           {"setPhase": [".paladinReact"]},
           {"log": [{"format": ["Paladin may reroll rally (rolled {})", "lastDieRoll"]}]}
         ]},
         {"seq": [
           {"resolveRallyWithStoredRoll": []},
           {"set": ["pendingRoll", ".none"]}
         ]}
       ]}
     ]}},

    // Resolve rally using lastDieRoll from state
    {"name": "resolveRallyWithStoredRoll",
     "params": [],
     "body": {"let": ["roll", "lastDieRoll",
       "drm", {"totalRallyDRM": []},
       {"seq": [
         {"if": [{"and": [{"!=": ["$roll", 1]},
                            {">": [{"+": ["$roll", "$drm"]}, 4]}]},
           {"raiseMorale": []},
           {"log": [{"format": ["Rally failed: {} + {} <= 4", "$roll", "$drm"]}]}
         ]},
         {"increment": ["heroicPointsSpent", 1]},
         {"log": [{"format": ["Rally: rolled {} + {}", "$roll", "$drm"]}]}
       ]}
     ]}},

    // Dispatch pending roll resolution based on type
    {"name": "resolvePendingRoll",
     "params": [],
     "body": {"seq": [
       {"if": [{"==": ["pendingRoll", ".melee"]},
         {"seq": [
           {"resolveMelee": ["pendingSlot"]},
           {"set": ["pendingSlot", null]}
         ]}
       ]},
       {"if": [{"==": ["pendingRoll", ".ranged"]},
         {"seq": [
           {"resolveRanged": ["pendingSlot"]},
           {"set": ["pendingSlot", null]}
         ]}
       ]},
       {"if": [{"==": ["pendingRoll", ".heroicAttack"]},
         {"seq": [
           {"resolveHeroicWithStoredRoll": ["pendingHero", "pendingSlot"]},
           {"set": ["pendingSlot", null]},
           {"set": ["pendingHero", null]}
         ]}
       ]},
       {"if": [{"==": ["pendingRoll", ".rally"]},
         {"resolveRallyWithStoredRoll": []}
       ]},
       {"set": ["pendingRoll", ".none"]}
     ]}}
  ],

  // ═══════════════════════════════════════════════════════════════
  // METADATA
  // ═══════════════════════════════════════════════════════════════
  "metadata": {
    "ai": {
      "heuristic": {"if": ["ended",
        {"if": ["victory", 1.0,
          {"*": [0.5, {"/": ["timePosition", 15.0]}]}]},
        {"+": [{"*": [0.5, {"/": ["timePosition", 15.0]}]}, 0.25]}
      ]}
    }
  }
}
