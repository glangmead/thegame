      {"name": "armyStrengthDict", "key": "ArmySlot", "value": "Int"},
      {"name": "heroLocationDict", "key": "HeroType", "value": "HeroLocation"},
      {"name": "defenderPosition", "key": "DefenderType", "value": "Int"},
      {"name": "spellStatusDict", "key": "SpellType", "value": "SpellStatus"},
