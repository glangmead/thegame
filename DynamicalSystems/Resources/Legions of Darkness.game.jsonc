      {"name": "heroDead", "element": "HeroType"},
      {"name": "breaches", "element": "Track"},
      {"name": "barricades", "element": "Track"},
      {"name": "acidEligibleSlots", "element": "ArmySlot"}
    ],
    "decks": [
      {"name": "dayDeck", "cardType": "Card"},
      {"name": "nightDeck", "cardType": "Card"}
    ],
    "optionals": [
      {"name": "currentCard", "type": "Card"},
      {"name": "bloodyBattleArmy", "type": "ArmySlot"},
      {"name": "slowedArmy", "type": "ArmySlot"}
    ],
    "lists": []
  },

