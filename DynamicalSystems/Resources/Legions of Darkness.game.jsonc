// Legions of Darkness
// Solo castle defense — defend against 5 approaching armies using defenders, heroes, and spells.
// Greenskin Horde scenario. Turn: Card → Army Advance → Event → Action Phase → Housekeeping.
// Victory: survive through Final Twilight (time position 15).
// Defeat: army enters castle through a breach, or all three defender types at zero.
{
  "game": "Legions of Darkness",
  "players": 1,

  "components": {
    "enums": [
      {"name": "Phase", "values": ["setup", "card", "army", "event", "action",
                                    "housekeeping", "paladinReact"]},
      {"name": "ArmySlot", "values": ["east", "west", "gate1", "gate2", "sky", "terror"],
       "player": 1,
       "displayNames": ["East", "West", "Gate 1", "Gate 2", "Sky", "Terror"]},
      {"name": "HeroType", "values": ["warrior", "wizard", "ranger", "rogue", "paladin", "cleric"],
       "player": 0,
       "displayNames": ["Warrior", "Wizard", "Ranger", "Rogue", "Paladin", "Cleric"]},
      {"name": "DefenderType", "values": ["menAtArms", "archers", "priests"],
       "displayNames": ["Men-at-Arms", "Archers", "Priests"]},
      {"name": "UpgradeType", "values": ["grease", "oil", "acid", "lava"],
       "displayNames": ["Grease", "Oil", "Acid", "Lava"]},
      {"name": "SpellType", "values": ["fireball", "slow", "chainLightning", "fortune",
                                        "cureWounds", "massHeal", "divineWrath", "inspire", "raiseDead"],
       "displayNames": ["Fireball", "Slow", "Chain Lightning", "Fortune",
                         "Cure Wounds", "Mass Heal", "Divine Wrath", "Inspire", "Raise Dead"]},
      {"name": "SpellStatus", "values": ["faceDown", "known", "cast"]},
      {"name": "Morale", "values": ["low", "normal", "high"]},
      {"name": "Track", "values": ["east", "west", "gate", "terror", "sky"]},
      {"name": "HeroLocation", "values": ["reserves", "east", "west", "gate", "terror", "sky"]},
      {"name": "DeckType", "values": ["day", "night"]},
      {"name": "PendingRoll", "values": ["none",
        "meleeEast", "meleeWest", "meleeGate1", "meleeGate2", "meleeSky", "meleeTerror",
        "rangedEast", "rangedWest", "rangedGate1", "rangedGate2", "rangedSky",
        "buildGreaseEast", "buildGreaseWest", "buildGreaseGate",
        "buildOilEast", "buildOilWest", "buildOilGate",
        "buildAcidEast", "buildAcidWest", "buildAcidGate",
        "buildLavaEast", "buildLavaWest", "buildLavaGate",
        "barricadeEast", "barricadeWest", "barricadeGate",
        "chant",
        "heroicAttackWarriorEast", "heroicAttackWarriorWest", "heroicAttackWarriorGate1",
        "heroicAttackWarriorGate2", "heroicAttackWarriorSky", "heroicAttackWarriorTerror",
        "heroicAttackWizardEast", "heroicAttackWizardWest", "heroicAttackWizardGate1",
        "heroicAttackWizardGate2", "heroicAttackWizardSky", "heroicAttackWizardTerror",
        "heroicAttackRangerEast", "heroicAttackRangerWest", "heroicAttackRangerGate1",
        "heroicAttackRangerGate2", "heroicAttackRangerSky", "heroicAttackRangerTerror",
        "heroicAttackRogueEast", "heroicAttackRogueWest", "heroicAttackRogueGate1",
        "heroicAttackRogueGate2", "heroicAttackRogueSky", "heroicAttackRogueTerror",
        "heroicAttackPaladinEast", "heroicAttackPaladinWest", "heroicAttackPaladinGate1",
        "heroicAttackPaladinGate2", "heroicAttackPaladinSky", "heroicAttackPaladinTerror",
        "heroicAttackClericEast", "heroicAttackClericWest", "heroicAttackClericGate1",
        "heroicAttackClericGate2", "heroicAttackClericSky", "heroicAttackClericTerror",
        "rally",
        "questAction1", "questAction2", "questAction3", "questAction4",
        "questHeroic1", "questHeroic2", "questHeroic3"
      ]}
    ],

    "structs": [],

    "functions": [
      // Army strength by slot (set during setup via dict, but useful for reference)
      {"name": "armyStrength", "domain": "ArmySlot",
       "mapping": {"east": 2, "west": 2, "gate1": 3, "gate2": 3, "sky": 4, "terror": 4}},
      // Upgrade build number
      {"name": "upgradeBuildNumber", "domain": "UpgradeType",
       "mapping": {"grease": 3, "oil": 3, "acid": 5, "lava": 5}},
      // Spell energy cost
      {"name": "spellCost", "domain": "SpellType",
       "mapping": {"fireball": 1, "slow": 2, "chainLightning": 3, "fortune": 4,
                   "cureWounds": 1, "massHeal": 2, "divineWrath": 3, "inspire": 3, "raiseDead": 4}},
      // Hero combat DRM
      {"name": "heroCombatDRM", "domain": "HeroType",
       "mapping": {"warrior": 2, "wizard": 1, "ranger": 1, "rogue": 1, "paladin": 1, "cleric": 1}},
      // Defender track values at each position (max attacks or chant DRM)
      // MenAtArms: [3, 2, 2, 2, 1, 0], Archers: [2, 2, 1, 1, 0], Priests: [2, 2, 1, 0]
      // We store these as separate per-position lookups below
      // Track max space
      {"name": "trackMaxSpace", "domain": "Track",
       "mapping": {"east": 6, "west": 6, "gate": 4, "terror": 3, "sky": 6}}
    ],

